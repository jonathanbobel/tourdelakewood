---
import '../styles/tailwind.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tour de Lakewood',
  description = 'A free 12-hour community cycling event through Lakewood, Ohio - July 11th, 2026.',
} = Astro.props;

const fullTitle = title === 'Tour de Lakewood' ? title : `${title} - Tour de Lakewood`;

const rawPath = Astro.url.pathname;
const pathname = rawPath.length > 1 ? rawPath.replace(/\/$/, '') : rawPath;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/records', label: 'Records' },
  { href: '/distance-calculator', label: 'Route Analyzer' },
  { href: '/results', label: 'Results' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tour de Lakewood" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:image" content={new URL('/tour-de-lakewood.svg', Astro.url).toString()} />
    <meta property="og:image:width" content="834" />
    <meta property="og:image:height" content="501" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/tour-de-lakewood.svg', Astro.url).toString()} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload reduces the FOUC window on first paint -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@500;600;700;800&display=swap"
    />
    <slot name="head" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H3YPPYY6Z1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H3YPPYY6Z1');
    </script>
  </head>
  <body>
    <header class="l-header">
      <nav class="l-nav">
        <a href="/" class="l-logo-link" aria-label="Tour de Lakewood - Home">
          <img src="/tour-de-lakewood.svg" alt="Tour de Lakewood" class="l-logo" />
        </a>

        <button
          id="l-toggle"
          class="l-hamburger"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="l-menu"
        >
          <span></span><span></span><span></span>
        </button>

        <ul class="l-menu" id="l-menu" role="list">
          {navLinks.map(({ href, label }) => {
            const active =
              href === '/'
                ? pathname === '/'
                : pathname === href || pathname.startsWith(href + '/');
            return (
              <li>
                <a
                  href={href}
                  class={'l-navlink' + (active ? ' l-navlink--active' : '')}
                  aria-current={active ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </header>

    <slot />

    <footer class="l-footer">
      <div class="l-footer-inner">
        <p class="l-footer-copy">&copy; 2026 Tour de Lakewood - Lakewood, Ohio</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('l-toggle');
      const menu = document.getElementById('l-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!isOpen));
          toggle.classList.toggle('is-open', !isOpen);
          menu.classList.toggle('is-open', !isOpen);
        });
        document.addEventListener('click', (e) => {
          if (!toggle.contains(e.target as Node) && !menu.contains(e.target as Node)) {
            toggle.setAttribute('aria-expanded', 'false');
            toggle.classList.remove('is-open');
            menu.classList.remove('is-open');
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --black: #0d0d0d;
    --purple: #5F259F;
    --yellow: #F2A900;
    --yellow-border: #D99600;
    --yellow-bg: #FEF6E6;
    --white: #ffffff;
    --gray-light: #f4f4f4;
    --card-border: #e3e3e3;
    --text: #1b1b1b;
    --text-muted: #555555;
    --text-soft: #666666;
    --nav-h: 88px;
    --radius: 1rem;
    --container: 1140px;
    color-scheme: light;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    /* 'Arial Narrow' is a close fallback for Barlow Condensed, reducing FOUC jarring */
    font-family: 'Barlow', 'Arial Narrow', system-ui, -apple-system, sans-serif;
    background: var(--white);
    color: var(--text);
  }
</style>

<style>
  .l-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 2px solid var(--black);
  }

  .l-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0;
    height: var(--nav-h);
  }

  .l-logo-link { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
  .l-logo { height: 80px; width: auto; display: block; }

  .l-menu {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .l-navlink {
    display: block;
    padding: 0.45rem 0.8rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-soft);
    text-decoration: none;
    border-radius: 0.35rem;
    transition: color 0.15s;
    position: relative;
  }

  .l-navlink::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0.8rem;
    right: 0.8rem;
    height: 4px;
    background: var(--yellow);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.18s ease;
  }

  .l-navlink:hover { color: var(--text); }
  .l-navlink:hover::after { transform: scaleX(1); }

  .l-navlink--active { color: var(--text); }
  .l-navlink--active::after { transform: scaleX(1); }

  .l-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: 2px solid var(--black);
    cursor: pointer;
    border-radius: 6px;
    flex-shrink: 0;
    margin-right: 1.5rem;
  }

  .l-hamburger span {
    display: block;
    height: 2px;
    background: var(--black);
    border-radius: 2px;
    transition: transform 0.22s ease, opacity 0.22s ease;
  }

  .l-hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .l-hamburger.is-open span:nth-child(2) { opacity: 0; }
  .l-hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .l-footer {
    background: var(--purple);
    padding: 2rem 1.5rem;
  }

  .l-footer-inner {
    max-width: var(--container);
    margin: 0 auto;
  }

  .l-footer-copy { margin: 0; font-size: 1rem; color: #aaa; }

  @media (max-width: 640px) {
    .l-hamburger { display: flex; }

    .l-menu {
      display: none;
      flex-direction: column;
      align-items: stretch;
      position: absolute;
      top: var(--nav-h);
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 2px solid var(--black);
      padding: 0.75rem 1rem;
      gap: 0.25rem;
    }

    .l-menu.is-open { display: flex; }
    .l-navlink { padding: 0.75rem 1rem; }
    .l-navlink::after { display: none; }
    .l-navlink--active { background: var(--yellow-bg); }
  }
</style>
