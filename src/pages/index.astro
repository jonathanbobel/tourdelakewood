---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tour de Lakewood"
  description="The greatest 12-hour cycling event in Lakewood, Ohio. Free, self-guided, and open to all. July 11th, 2026."
>
  <!-- BLACK HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <p class="grand-depart">Grand Départ - July 11, 2026</p>
        <h1 class="hero-h1">
          Tour<br />
          <em>de</em><br />
          Lakewood
        </h1>
        <p class="hero-subtitle">
          12 hours. One city. Every street, every block, every neighborhood. The most epic
          community cycling event Lakewood, Ohio has ever seen - or likely will ever see.
        </p>
        <div class="hero-cta">
          <a href="/about" class="btn-yellow">Learn about the ride</a>
          <a href="/distance-calculator" class="btn-ghost">Route Analyzer</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="countdown-card">
          <p class="cd-eyebrow">Le Départ dans&hellip;</p>
          <div class="countdown" aria-label="Countdown to July 11, 2026 at 8:00 AM">
            <div class="cd-block">
              <span class="cd-val" id="cd-days">00</span>
              <span class="cd-unit">Days</span>
            </div>
            <span class="cd-sep" aria-hidden="true">:</span>
            <div class="cd-block">
              <span class="cd-val" id="cd-hours">00</span>
              <span class="cd-unit">Hrs</span>
            </div>
            <span class="cd-sep" aria-hidden="true">:</span>
            <div class="cd-block">
              <span class="cd-val" id="cd-mins">00</span>
              <span class="cd-unit">Min</span>
            </div>
            <span class="cd-sep" aria-hidden="true">:</span>
            <div class="cd-block">
              <span class="cd-val" id="cd-secs">00</span>
              <span class="cd-unit">Sec</span>
            </div>
          </div>
          <div class="cd-meta">
            <div class="cd-meta-row">Saturday, July 11th, 2026</div>
            <div class="cd-meta-row">8:00 AM &ndash; 8:00 PM Eastern</div>
            <div class="cd-meta-row">Lakewood, Ohio (city-wide)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- YELLOW TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-inner">
      <span>FREE TO ENTER</span>
      <span class="t-dot">&middot;</span>
      <span>ALL SKILL LEVELS</span>
      <span class="t-dot">&middot;</span>
      <span>SELF-GUIDED</span>
      <span class="t-dot">&middot;</span>
      <span>JULY 11, 2026</span>
      <span class="t-dot">&middot;</span>
      <span>LAKEWOOD, OH</span>
      <span class="t-dot">&middot;</span>
      <span>12 HOURS</span>
      <span class="t-dot">&middot;</span>
      <span>NO MANDATORY ROUTE</span>
    </div>
  </div>

  <!-- WHAT IS IT -->
  <section class="section-white">
    <div class="container">
      <div class="editorial-grid">
        <div class="editorial-label">
          <p class="section-tag">The Event</p>
        </div>
        <div class="editorial-body">
          <h2 class="section-h2">The greatest cycling event<br />Lakewood has ever hosted.</h2>
          <p class="section-body">
            Tour de Lakewood is a free, self-guided 12-hour cycling event set entirely within the
            city limits of Lakewood, Ohio. No mandatory course. No entry fee. No peloton
            blocking traffic on Detroit.
          </p>
          <p class="section-body">
            Riders choose their own route, their own pace, and their own distance. Race for 12
            hours straight or cruise for one. The only rule: have fun and try to cover more of
            this great city than everyone else.
          </p>
          <a href="/about" class="text-cta">Full event details &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAGE CARDS -->
  <section class="stage-section">
    <div class="container">
      <p class="section-tag-light">The Numbers</p>
      <div class="stage-grid">
        <div class="stage-card">
          <div class="stage-num">12H</div>
          <div class="stage-lbl">Duration</div>
          <p class="stage-desc">8 AM to 8 PM. Arrive whenever. Stay as long as you like.</p>
        </div>
        <div class="stage-card stage-card--yellow">
          <div class="stage-num">$0</div>
          <div class="stage-lbl">Entry Fee</div>
          <p class="stage-desc">Completely free. No registration, no waivers, no bibs.</p>
        </div>
        <div class="stage-card">
          <div class="stage-num">&infin;</div>
          <div class="stage-lbl">Distance</div>
          <p class="stage-desc">No minimum, no maximum. One mile or fifty - your race, your rules.</p>
        </div>
        <div class="stage-card">
          <div class="stage-num">5.5<span class="stage-unit">mi&sup2;</span></div>
          <div class="stage-lbl">The Arena</div>
          <p class="stage-desc">The full 5.5 square miles of Lakewood, Ohio. Every street, fair game.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ROUTE ANALYZER CTA -->
  <section class="analyzer-section">
    <div class="container">
      <div class="analyzer-inner">
        <div class="analyzer-text">
          <p class="section-tag">Route Analyzer</p>
          <h2 class="analyzer-h2">Measure every meter<br />inside Lakewood.</h2>
          <p class="analyzer-body">
            Upload a GPX file from Strava, Garmin, or any GPS device. The route analyzer
            calculates exactly how many miles of your ride fell inside Lakewood city limits -
            and what percentage of the city you covered. Compare multiple rides. Declare a winner.
          </p>
          <a href="/distance-calculator" class="btn-black">Open Route Analyzer &rarr;</a>
        </div>
        <div class="analyzer-graphic" aria-hidden="true">
          <div class="mock-card">
            <div class="mock-val">12.4</div>
            <div class="mock-lbl">Miles in Lakewood</div>
            <div class="mock-bar-wrap">
              <div class="mock-bar">
                <div class="mock-fill" style="width:68%"></div>
              </div>
              <span class="mock-pct">68.2%</span>
            </div>
            <div class="mock-sub">of Lakewood city covered</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (() => {
    const TARGET = new Date('2026-07-11T08:00:00-04:00').getTime();
    const pad = (n: number) => String(n).padStart(2, '0');

    const tick = () => {
      const diff = Math.max(0, TARGET - Date.now());
      const s = Math.floor(diff / 1000);
      const days  = Math.floor(s / 86400);
      const hours = Math.floor((s % 86400) / 3600);
      const mins  = Math.floor((s % 3600) / 60);
      const secs  = s % 60;

      const d = document.getElementById('cd-days');
      const h = document.getElementById('cd-hours');
      const m = document.getElementById('cd-mins');
      const sc = document.getElementById('cd-secs');

      if (d)  d.textContent  = String(days);
      if (h)  h.textContent  = pad(hours);
      if (m)  m.textContent  = pad(mins);
      if (sc) sc.textContent = pad(secs);
    };

    tick();
    setInterval(tick, 1000);
  })();
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    background: var(--purple);
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero-inner {
    max-width: var(--container);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3.5rem;
    align-items: start;
  }

  .grand-depart {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--yellow);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .hero-h1 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(5rem, 13vw, 10rem);
    font-weight: 800;
    line-height: 0.88;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0 0 1.5rem;
  }

  .hero-h1 em {
    font-style: normal;
    color: var(--yellow);
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.65;
    color: #ccc;
    max-width: 30rem;
    margin: 0 0 2rem;
  }

  .hero-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn-yellow {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 0.35rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-yellow:hover { background: #F5B400; }

  .btn-ghost {
    display: inline-block;
    background: transparent;
    color: var(--white);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 0.35rem;
    border: 2px solid rgba(255,255,255,0.25);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.6); }

  .btn-black {
    display: inline-block;
    background: var(--purple);
    color: var(--white);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 0.35rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-black:hover { background: #222; }

  /* Countdown card */
  .countdown-card {
    background: #1b1b1b;
    border: 1px solid #333;
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
  }

  .cd-eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #999;
    font-style: italic;
    margin: 0 0 1rem;
  }

  .countdown {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .cd-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .cd-val {
    display: block;
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1;
    color: var(--yellow);
    min-width: 72px;
    text-align: center;
  }

  .cd-unit {
    display: block;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #999;
  }

  .cd-sep {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 3.25rem;
    font-weight: 700;
    color: #2a2a2a;
    line-height: 1;
    flex-shrink: 0;
    /* nudge down to optically center with the numbers */
    padding-top: 0.05em;
  }

  .cd-meta { display: flex; flex-direction: column; gap: 0.55rem; }

  .cd-meta-row {
    font-size: 1rem;
    color: #aaa;
  }

  /* ---- Ticker ---- */
  .ticker {
    background: var(--yellow);
    border-top: 2px solid var(--yellow-border);
    border-bottom: 2px solid var(--yellow-border);
    padding: 0.7rem 0;
    overflow: hidden;
  }

  .ticker-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--black);
    flex-wrap: wrap;
  }

  .t-dot { color: rgba(0,0,0,0.3); }

  /* ---- Shared section base ---- */
  .container { max-width: var(--container); margin: 0 auto; }

  .section-tag {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-soft);
    font-weight: 700;
    margin: 0 0 1.25rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--yellow);
  }

  .section-tag-light {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #ccc;
    font-weight: 700;
    margin: 0 0 1.5rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--yellow);
  }

  .section-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.02;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0 0 1.1rem;
    color: var(--text);
  }

  .section-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 0.85rem;
    max-width: 38rem;
  }

  .text-cta {
    display: inline-block;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border-bottom: 2px solid var(--yellow);
    padding-bottom: 2px;
    margin-top: 0.5rem;
    transition: border-color 0.15s;
  }
  .text-cta:hover { border-color: var(--text); }

  /* ---- What is it ---- */
  .section-white {
    background: var(--white);
    padding: 5.5rem 1.5rem;
    border-bottom: 1px solid #e8e8e8;
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  .editorial-label { padding-top: 0.4rem; }

  /* ---- Stage cards ---- */
  .stage-section {
    background: var(--purple);
    padding: 5rem 1.5rem;
  }

  .stage-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid #2a2a2a;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .stage-card {
    background: #1b1b1b;
    padding: 2rem 1.5rem;
    border-right: 1px solid #2a2a2a;
  }

  .stage-card:last-child { border-right: none; }

  .stage-card--yellow {
    background: var(--yellow);
  }

  .stage-card--yellow .stage-num,
  .stage-card--yellow .stage-lbl,
  .stage-card--yellow .stage-desc { color: var(--black); }

  .stage-card--yellow .stage-lbl { color: #444; }
  .stage-card--yellow .stage-desc { color: #555; }

  .stage-num {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1;
    color: var(--yellow);
    margin-bottom: 0.2rem;
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
  }

  .stage-unit {
    font-size: 1.4rem;
    font-weight: 600;
  }

  .stage-lbl {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #999;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .stage-desc {
    font-size: 1rem;
    line-height: 1.55;
    color: #aaa;
    margin: 0;
  }

  /* ---- Route Analyzer CTA ---- */
  .analyzer-section {
    background: var(--white);
    padding: 5.5rem 1.5rem;
    border-top: 1px solid #e8e8e8;
  }

  .analyzer-inner {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: center;
  }

  .analyzer-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.02;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    color: var(--text);
  }

  .analyzer-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
    max-width: 34rem;
  }

  /* Mock card */
  .mock-card {
    background: #1b1b1b;
    border-radius: var(--radius);
    padding: 1.75rem;
    color: var(--white);
  }

  .mock-val {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 4rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
  }

  .mock-lbl {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin-bottom: 1rem;
    margin-top: 0.15rem;
  }

  .mock-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .mock-bar {
    flex: 1;
    height: 6px;
    background: #222;
    border-radius: 3px;
    overflow: hidden;
  }

  .mock-fill {
    height: 100%;
    background: var(--yellow);
    border-radius: 3px;
  }

  .mock-pct {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--yellow);
    flex-shrink: 0;
  }

  .mock-sub {
    font-size: 1rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Responsive ---- */
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .editorial-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .stage-grid { grid-template-columns: repeat(2, 1fr); }
    .stage-card { border-right: none; border-bottom: 1px solid #2a2a2a; }
    .stage-card:nth-child(odd) { border-right: 1px solid #2a2a2a; }
    .stage-card:nth-child(3),
    .stage-card:nth-child(4) { border-bottom: none; }
    .analyzer-inner { grid-template-columns: 1fr; }
    .analyzer-graphic { display: none; }
  }

  @media (max-width: 560px) {
    .hero { padding: 3rem 1.25rem 3rem; }
    .section-white, .analyzer-section { padding: 3.5rem 1.25rem; }
    .stage-section { padding: 3.5rem 1.25rem; }
    .stage-grid { grid-template-columns: 1fr; }
    .stage-card { border-right: none !important; }
    .stage-card:last-child { border-bottom: none; }
    .cd-val { font-size: 2.5rem; min-width: 54px; }
    .countdown { gap: 0.25rem; }
  }
</style>
