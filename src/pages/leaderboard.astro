---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Leaderboard"
  description="Tour de Lakewood 2026 leaderboard - submit your GPX after the July 11th ride to claim your spot."
>
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js"></script>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Tour de Lakewood 2026</p>
      <h1 class="hero-h1">
        Results<br />
        <em>Board</em>
      </h1>
    </div>
  </section>

  <!-- TBD - shown before July 11 8am -->
  <section id="tbd-section" class="tbd-section">
    <div class="container">
      <div class="tbd-card">
        <div class="tbd-badge">
          <span class="dot"></span>
          <span>Event coming up - no results yet</span>
        </div>
        <h2 class="tbd-h2">Check back on July 11th.</h2>
        <p class="tbd-body">
          Tour de Lakewood takes place on July 11th, 2026. After the ride, submit
          your GPX here to claim your spot on three leaderboards: most total distance
          in Lakewood, most map coverage, and most elevation gain.
        </p>
        <p class="tbd-eyebrow">Event starts in</p>
        <div class="countdown" aria-label="Countdown to July 11, 2026 at 8:00 AM">
          <div class="cd-block">
            <span class="cd-val" id="r-days">00</span>
            <span class="cd-unit">Days</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-hours">00</span>
            <span class="cd-unit">Hrs</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-mins">00</span>
            <span class="cd-unit">Min</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-secs">00</span>
            <span class="cd-unit">Sec</span>
          </div>
        </div>
        <div class="tbd-meta">
          <div class="tbd-meta-row">Saturday, July 11th, 2026</div>
          <div class="tbd-meta-row">8:00 AM &ndash; 8:00 PM Eastern</div>
          <div class="tbd-meta-row">Lakewood, Ohio</div>
        </div>
        <div class="tbd-actions">
          <a href="/about" class="btn-yellow">Learn about the ride</a>
          <a href="/distance-calculator" class="btn-ghost">Route Analyzer</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SUBMIT RESULTS - unlocks July 11 8am (or ?preview for testing) -->
  <section id="submit-section" class="submit-section" style="display:none">
    <div class="container">
      <div id="preview-banner" class="preview-banner" style="display:none">
        Preview mode - results page is not yet live to the public.
      </div>

      <p class="section-tag">Submit Your Results</p>
      <h2 class="submit-h2">Upload your GPX,<br />claim your place.</h2>

      <div class="submit-layout">

        <!-- Upload / analysis card -->
        <div class="upload-card">

          <!-- drop zone (default visible state) -->
          <div id="dropZone" class="drop-zone">
            <div class="drop-icon-wrap">
              <svg class="drop-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            </div>
            <p class="drop-label">Drop your GPX file here</p>
            <p class="drop-hint">or click to upload &middot; one file</p>
            <input type="file" id="fileInput" accept=".gpx" class="sr-only" />
          </div>

          <!-- processing -->
          <div id="processingState" class="processing-state" style="display:none">
            <div class="spinner"></div>
            <p class="processing-text">Analyzing route&hellip;</p>
            <p class="processing-sub" id="processingMsg">Loading road network&hellip;</p>
          </div>

          <!-- stats + submit form -->
          <div id="statsState" class="stats-state" style="display:none">
            <div class="stats-grid">
              <div class="stat-item">
                <div class="stat-val" id="stat-miles">-</div>
                <div class="stat-lbl">Miles in Lakewood</div>
              </div>
              <div class="stat-item">
                <div class="stat-val" id="stat-coverage">-</div>
                <div class="stat-lbl">Road Coverage</div>
              </div>
              <div class="stat-item">
                <div class="stat-val" id="stat-elevation">-</div>
                <div class="stat-lbl">Elevation Gain</div>
              </div>
            </div>
            <div class="name-form">
              <label class="name-label" for="riderName">Your name for the leaderboard</label>
              <input type="text" id="riderName" class="name-input" placeholder="e.g. Jon Bobel" maxlength="60" autocomplete="name" />
              <button id="submitBtn" class="submit-btn">Post to Leaderboard &rarr;</button>
              <button id="resetBtn" class="reset-link">Upload a different file</button>
            </div>
          </div>

          <!-- success -->
          <div id="successState" class="success-state" style="display:none">
            <div class="success-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="success-svg" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h3 class="success-title">Results submitted!</h3>
            <p class="success-desc">Your results are on the leaderboard below.</p>
            <button id="submitAnother" class="reset-link">Submit another</button>
          </div>

          <!-- error -->
          <div id="errorState" class="error-state" style="display:none">
            <p id="errorMsg" class="error-msg"></p>
            <button id="retryBtn" class="reset-link">Try again</button>
          </div>

        </div>

        <!-- info panel -->
        <div class="submit-info">
          <h3 class="info-title">How it works</h3>
          <ol class="info-steps">
            <li>Upload the GPX from your Strava, Garmin, or any GPS device</li>
            <li>Your route is analyzed: miles inside Lakewood, road coverage %, and elevation gain</li>
            <li>Enter your name and post to the leaderboard</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- LEADERBOARD - unlocks July 11 8am alongside submit section -->
  <section id="leaderboard-section" class="results-live-section" style="display:none">
    <div class="container">
      <p class="section-tag">2026 Leaderboard</p>

      <div id="lb-empty" class="lb-empty">
        <p class="lb-empty-msg">No results yet - be the first to submit your GPX above.</p>
      </div>

      <div class="lb-grid" id="lb-grid" style="display:none">
        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Distance</h2>
            <p class="lb-sub">Total miles within Lakewood</p>
          </div>
          <div id="lb-distance" class="lb-list"></div>
        </div>
        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Coverage</h2>
            <p class="lb-sub">% of Lakewood roads ridden</p>
          </div>
          <div id="lb-coverage" class="lb-list"></div>
        </div>
        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Elevation</h2>
            <p class="lb-sub">Total elevation gain</p>
          </div>
          <div id="lb-elevation" class="lb-list"></div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js';

  // ── Supabase ──────────────────────────────────────────────────────────────
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = (SUPABASE_URL && SUPABASE_KEY)
    ? createClient(SUPABASE_URL, SUPABASE_KEY)
    : null;

  // ── Feature gate - opened July 10 2026 ──────────────────────────────────
  const RACE_START_MS = new Date('2026-07-10T00:00:00-04:00').getTime();
  const preview     = new URLSearchParams(location.search).has('preview');
  const raceStarted = preview || Date.now() >= RACE_START_MS;

  const tbdEl    = document.getElementById('tbd-section');
  const submitEl = document.getElementById('submit-section');
  const lbEl     = document.getElementById('leaderboard-section');
  const prevBanner = document.getElementById('preview-banner');

  if (raceStarted) {
    if (tbdEl)    tbdEl.style.display    = 'none';
    if (submitEl) submitEl.style.display = '';
    if (lbEl)     lbEl.style.display     = '';
  }
  if (prevBanner && preview) prevBanner.style.display = '';

  // ── Lakewood boundary (same polygon as Route Analyzer) ───────────────────
