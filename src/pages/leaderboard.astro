        [-81.82703, 41.496913],
        [-81.843982, 41.494593]
      ]]
    },
    properties: { name: 'Lakewood, OH' }
  };

  // ── Road network (shared cache key with Route Analyzer) ───────────────────
  const OVERPASS     = 'https://overpass-api.de/api/interpreter';
  const ROAD_CACHE_K = 'tdl_roads_v4';
  const CACHE_TTL    = 7 * 24 * 60 * 60 * 1000;
  const SNAP_KM      = 0.025;
  const HW_FILTER    = 'primary|secondary|tertiary|unclassified|residential|living_street|cycleway';

  let roadNet = null;
  let roadPromise = null;

  async function fetchRoads() {
    if (roadNet) return roadNet;
    try {
      const c = JSON.parse(localStorage.getItem(ROAD_CACHE_K));
      if (c && Date.now() - c.ts < CACHE_TTL) { roadNet = c.d; return roadNet; }
    } catch (_) {}
    const q = `[out:json][timeout:60];(way["highway"~"^(${HW_FILTER})$"](41.463,-81.844,41.501,-81.769););out geom;`;
    const r  = await fetch(OVERPASS, { method: 'POST', body: q });
    if (!r.ok) throw new Error(`Overpass API error ${r.status}`);
    const js = await r.json();
    let totalMiles = 0;
    const features = [];
    for (const el of js.elements) {
      if (el.type !== 'way' || !el.geometry || el.geometry.length < 2) continue;
      const coords = el.geometry.map(n => [n.lon, n.lat]);
      const feat = {
        type: 'Feature',
        properties: { id: el.id },
        geometry: { type: 'LineString', coordinates: coords }
      };
      if (!turf.booleanIntersects(feat, lakewoodBoundary)) continue;
      totalMiles += turf.length(feat, { units: 'miles' });
      features.push(feat);
    }
    roadNet = { type: 'FeatureCollection', features, totalMiles };
    try { localStorage.setItem(ROAD_CACHE_K, JSON.stringify({ ts: Date.now(), d: roadNet })); } catch (_) {}
    return roadNet;
  }

  function loadRoads() {
    if (!roadPromise) roadPromise = fetchRoads();
    return roadPromise;
  }

  async function analyzeRoads(coords) {
    const net     = await loadRoads();
    const buf     = turf.buffer(turf.lineString(coords), SNAP_KM, { units: 'kilometers' });
    const bufEdge = turf.polygonToLine(buf);
    let coveredMiles = 0;
    for (const road of net.features) {
      if (!turf.booleanIntersects(road, buf)) continue;
      let inside = 0;
      try {
        const split = turf.lineSplit(road, bufEdge);
        const segs  = split.features.length > 0 ? split.features : [road];
        for (const seg of segs) {
          const len = turf.length(seg, { units: 'miles' });
          if (!len) continue;
          const mid = turf.along(seg, len / 2, { units: 'miles' });
          if (turf.booleanPointInPolygon(mid, buf)) inside += len;
        }
      } catch (_) {
        inside = turf.length(road, { units: 'miles' });
      }
      coveredMiles += inside;
    }
    const pct = net.totalMiles > 0 ? Math.min(100, (coveredMiles / net.totalMiles) * 100) : 0;
    return { pct };
  }

  // ── GPX parsing ───────────────────────────────────────────────────────────
  function parseGPX(gpxText) {
    const parser = new DOMParser();
    const doc    = parser.parseFromString(gpxText, 'text/xml');
    const trkpts = [...doc.querySelectorAll('trkpt')];
    const coords = trkpts.map(pt => [
      parseFloat(pt.getAttribute('lon')),
      parseFloat(pt.getAttribute('lat')),
    ]);
    if (!coords.length) {
      doc.querySelectorAll('wpt').forEach(pt => {
        coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
      });
    }
    return { coords, trkpts };
  }

  function calcElevationGainFt(trkpts) {
    let gain = 0, prevEle = null, prevInside = false;
    for (const pt of trkpts) {
      const lon = parseFloat(pt.getAttribute('lon'));
      const lat = parseFloat(pt.getAttribute('lat'));
      const inside = turf.booleanPointInPolygon(turf.point([lon, lat]), lakewoodBoundary);
      const eleEl = pt.querySelector('ele');
      if (!eleEl) continue;
      const ele = parseFloat(eleEl.textContent.trim());
      if (isNaN(ele)) continue;
      if (prevEle !== null && ele > prevEle && inside && prevInside) {
        gain += (ele - prevEle);
      }
      prevEle = ele;
      prevInside = inside;
    }
    return gain * 3.28084; // metres → feet, Lakewood segments only
  }

  // ── UI state machine ──────────────────────────────────────────────────────
  const STATES = {
    upload:     'dropZone',
    processing: 'processingState',
    stats:      'statsState',
    success:    'successState',
    error:      'errorState',
  };

  function setState(state) {
    for (const [s, id] of Object.entries(STATES)) {
      const el = document.getElementById(id);
      if (el) el.style.display = s === state ? '' : 'none';
    }
  }

  let currentStats = null;

  // ── File handling ─────────────────────────────────────────────────────────
  const dropZone  = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');

  dropZone?.addEventListener('click', () => fileInput?.click());
  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) processFile(fileInput.files[0]);
  });
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('dragover');
  });
  dropZone?.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    const file = e.dataTransfer?.files[0];
    if (file) processFile(file);
  });

  document.getElementById('resetBtn')?.addEventListener('click', resetForm);
  document.getElementById('retryBtn')?.addEventListener('click', resetForm);
  document.getElementById('submitAnother')?.addEventListener('click', () => {
    resetForm();
    loadLeaderboard();
  });

  function resetForm() {
    currentStats = null;
    if (fileInput) fileInput.value = '';
    const btn = document.getElementById('submitBtn');
    if (btn) { btn.textContent = 'Post to Leaderboard →'; btn.disabled = false; }
    const nameInput = document.getElementById('riderName');
    if (nameInput) nameInput.value = '';
    setState('upload');
  }

  // ── Analysis pipeline ─────────────────────────────────────────────────────
  async function processFile(file) {
    setState('processing');
    const msgEl = document.getElementById('processingMsg');

    try {
      if (msgEl) msgEl.textContent = 'Parsing GPX file…';
      const text = await file.text();
      const { coords, trkpts } = parseGPX(text);
      if (!coords.length) throw new Error('No GPS track data found in this file.');

      if (msgEl) msgEl.textContent = 'Loading Lakewood road network…';

      let lakewoodMiles = 0;
      let insideSegFound = false;
      if (coords.length > 1) {
        const line = turf.lineString(coords);
        try {
          const split = turf.lineSplit(line, turf.polygonToLine(lakewoodBoundary));
          if (split?.features?.length) {
            for (const seg of split.features) {
              const len = turf.length(seg, { units: 'miles' });
              if (!len) continue;
              const mid = turf.along(seg, len / 2, { units: 'miles' });
              if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) {
                lakewoodMiles += len;
                insideSegFound = true;
              }
            }
          }
        } catch (_) {}

        // Fallback: segment midpoints - runs when route doesn't cross the boundary
        // (entirely inside or entirely outside Lakewood) or when lineSplit throws
        if (!insideSegFound) {
          for (let j = 0; j < coords.length - 1; j++) {
            const [a, b] = [coords[j], coords[j + 1]];
            const seg = turf.lineString([a, b]);
            const len = turf.length(seg, { units: 'miles' });
            if (!len) continue;
            const mid = turf.point([(a[0] + b[0]) / 2, (a[1] + b[1]) / 2]);
            if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) lakewoodMiles += len;
          }
        }
      }

      if (msgEl) msgEl.textContent = 'Analyzing road coverage…';
      const roads  = await analyzeRoads(coords);
      const elevFt = calcElevationGainFt(trkpts);

      currentStats = {
        lakewoodMiles: Math.round(lakewoodMiles * 100) / 100,
        coveragePct:   Math.round(roads.pct * 100) / 100,
        elevationFt:   Math.round(elevFt),
      };

      const mEl = document.getElementById('stat-miles');
      const cEl = document.getElementById('stat-coverage');
      const eEl = document.getElementById('stat-elevation');
      if (mEl) mEl.textContent = currentStats.lakewoodMiles.toFixed(2) + ' mi';
      if (cEl) cEl.textContent = currentStats.coveragePct.toFixed(1) + '%';
      if (eEl) eEl.textContent = currentStats.elevationFt.toLocaleString() + ' ft';

      setState('stats');
    } catch (err) {
      const errEl = document.getElementById('errorMsg');
      if (errEl) errEl.textContent = err.message || 'Analysis failed. Please try again.';
      setState('error');
    }
  }

  // ── Submit to Supabase ────────────────────────────────────────────────────
  document.getElementById('submitBtn')?.addEventListener('click', async () => {
    const nameInput = document.getElementById('riderName');
    const name = nameInput?.value.trim();
    if (!name) { nameInput?.focus(); return; }
    if (!currentStats) return;

    const btn = document.getElementById('submitBtn');
    btn.textContent = 'Submitting…';
    btn.disabled = true;

    if (!supabase) {
      const errEl = document.getElementById('errorMsg');
      if (errEl) errEl.textContent = 'Leaderboard database not yet configured. Contact the organizer.';
      setState('error');
      btn.textContent = 'Post to Leaderboard →';
      btn.disabled = false;
      return;
    }

    const { error } = await supabase.from('race_submissions').insert({
      rider_name:     name,
      lakewood_miles: currentStats.lakewoodMiles,
      coverage_pct:   currentStats.coveragePct,
      elevation_ft:   currentStats.elevationFt,
      year:           2026,
    });

    if (error) {
      const errEl = document.getElementById('errorMsg');
      if (errEl) errEl.textContent = `Submission failed: ${error.message}`;
      setState('error');
      btn.textContent = 'Post to Leaderboard →';
      btn.disabled = false;
    } else {
      setState('success');
      loadLeaderboard();
    }
  });

  // ── Leaderboard ───────────────────────────────────────────────────────────
  const RANK_CLASS = ['lb-rank--gold', 'lb-rank--silver', 'lb-rank--bronze'];

  function renderLbList(id, entries, field, fmtFn) {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = entries.map((e, i) => {
      const rowMod = i === 0 ? ' lb-row--winner' : i < 3 ? ' lb-row--podium' : '';
      return `
        <div class="lb-row${rowMod}">
          <span class="lb-rank ${RANK_CLASS[i] || ''}">${i + 1}</span>
          <span class="lb-name">${e.rider_name}</span>
          <span class="lb-val">${fmtFn(e[field])}</span>
        </div>`;
    }).join('');
  }

  async function loadLeaderboard() {
    const emptyEl = document.getElementById('lb-empty');
    const gridEl  = document.getElementById('lb-grid');
    const emptyMsg = emptyEl?.querySelector('.lb-empty-msg');

    if (!supabase) {
      if (emptyMsg) emptyMsg.textContent = 'Leaderboard not yet configured - check back on race day.';
      if (emptyEl) emptyEl.style.display = '';
      if (gridEl)  gridEl.style.display  = 'none';
      return;
    }

    const { data } = await supabase
      .from('race_submissions')
      .select('rider_name, lakewood_miles, coverage_pct, elevation_ft')
      .eq('year', 2026)
      .order('submitted_at', { ascending: true });

    if (!data?.length) {
      if (emptyEl) emptyEl.style.display = '';
      if (gridEl)  gridEl.style.display  = 'none';
      return;
    }

    if (emptyEl) emptyEl.style.display = 'none';
    if (gridEl)  gridEl.style.display  = '';

    const byDist = [...data].sort((a, b) => b.lakewood_miles - a.lakewood_miles);
    const byCov  = [...data].sort((a, b) => b.coverage_pct   - a.coverage_pct  );
    const byElev = [...data].sort((a, b) => b.elevation_ft   - a.elevation_ft  );

    renderLbList('lb-distance', byDist, 'lakewood_miles', v => `${(+v).toFixed(2)} mi`);
    renderLbList('lb-coverage', byCov,  'coverage_pct',   v => `${(+v).toFixed(1)}%`);
    renderLbList('lb-elevation', byElev, 'elevation_ft',  v => `${Math.round(+v).toLocaleString()} ft`);
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  if (raceStarted) {
    setState('upload');
    loadLeaderboard();
  } else {
    // countdown timer for TBD section
    const TARGET = new Date('2026-07-11T08:00:00-04:00').getTime();
    const pad = n => String(n).padStart(2, '0');
    const tick = () => {
      const diff = Math.max(0, TARGET - Date.now());
      const s    = Math.floor(diff / 1000);
      const d  = document.getElementById('r-days');
      const h  = document.getElementById('r-hours');
      const m  = document.getElementById('r-mins');
      const sc = document.getElementById('r-secs');
      if (d)  d.textContent  = String(Math.floor(s / 86400));
      if (h)  h.textContent  = pad(Math.floor((s % 86400) / 3600));
      if (m)  m.textContent  = pad(Math.floor((s % 3600) / 60));
      if (sc) sc.textContent = pad(s % 60);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

