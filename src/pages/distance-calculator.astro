			});

			document.getElementById('fileInput').addEventListener('change', handleFileSelect);

			// Drag and drop handlers
			document.getElementById('fileInputContainer').addEventListener('dragover', (e) => {
				e.preventDefault();
				e.currentTarget.classList.add('dragover');
			});

			document.getElementById('fileInputContainer').addEventListener('dragleave', (e) => {
				e.currentTarget.classList.remove('dragover');
			});

			document.getElementById('fileInputContainer').addEventListener('drop', (e) => {
				e.preventDefault();
				e.currentTarget.classList.remove('dragover');
				handleFileSelect({ target: { files: e.dataTransfer.files } });
			});

			function handleFileSelect(event) {
				const selectedFiles = Array.from(event.target.files);
				files = [...files, ...selectedFiles];
				updateFileList();
				document.getElementById('analyzeBtn').disabled = files.length === 0;
			}

			function updateFileList() {
				const fileList = document.getElementById('fileList');
				fileList.innerHTML = '';

				files.forEach((file, index) => {
					const fileItem = document.createElement('div');
					fileItem.className =
							'flex items-center justify-between p-4 bg-[#E25A28]/20 rounded-lg border-2 border-[#E25A28] transition-all duration-300 hover:bg-[#E25A28]/30 enhanced-card';
					fileItem.innerHTML = `
						<div class="font-medium text-[#1b1b1b] transition-colors duration-300 hover:text-[#E25A28]" style="color: ${file.name.includes('.gpx') ? '#E25A28' : '#E25A28'}">${file.name}</div>
						<button onclick="removeFile(${index})" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm transition-all duration-300 enhanced-button">
							Remove
						</button>
					`;
					fileList.appendChild(fileItem);
				});
			}

			function removeFile(index) {
				files.splice(index, 1);
				updateFileList();
				document.getElementById('analyzeBtn').disabled = files.length === 0;
			}

			// GPX parsing function
			function parseGPX(gpxText) {
				const parser = new DOMParser();
				const gpxDoc = parser.parseFromString(gpxText, 'text/xml');
				const coordinates = [];

				// Extract track points
				const trkpts = gpxDoc.querySelectorAll('trkpt');
				trkpts.forEach((trkpt) => {
					const lat = parseFloat(trkpt.getAttribute('lat'));
					const lon = parseFloat(trkpt.getAttribute('lon'));
					coordinates.push([lon, lat]);
				});

				// Extract waypoints if no track points
				if (coordinates.length === 0) {
					const wpts = gpxDoc.querySelectorAll('wpt');
					wpts.forEach((wpt) => {
						const lat = parseFloat(wpt.getAttribute('lat'));
						const lon = parseFloat(wpt.getAttribute('lon'));
						coordinates.push([lon, lat]);
					});
				}

				return coordinates;
			}

			// Analysis function
			async function analyzeFiles() {
				const resultsSection = document.getElementById('resultsSection');
				const results = document.getElementById('results');

				resultsSection.style.display = 'block';
				results.innerHTML =
					'<div class="text-center py-8"><div class="spinner"></div><div class="text-[#E25A28]">Analyzing GPX files...</div></div>';

				analysisResults = [];
				const colors = ['#E25A28', '#1C8282', '#363636', '#c8c6af', '#ff6b6b', '#4ecdc4'];
				const lakewoodAreaSqMiles = turf.area(lakewoodBoundary) / 2589988.11; // Convert m^2 -> sq miles

				try {
					for (let i = 0; i < files.length; i++) {
						const file = files[i];
						const gpxText = await file.text();
						const coordinates = parseGPX(gpxText);

						if (coordinates.length === 0) {
							throw new Error(`No coordinates found in ${file.name}`);
						}

						// Calculate metrics (route-geometry based)
						let distance = 0;
						let coverageArea = 0;
						let percentLakewoodTraveled = 0;
						let insideSegmentsForMap = [];

						if (coordinates.length > 1) {
							const routeLine = turf.lineString(coordinates);

							// --------
							// Distance #1: miles of the route inside Lakewood
							// --------
							try {
								// Prefer splitting by the polygon boundary for better accuracy.
								if (typeof turf.lineSplit === 'function' && typeof turf.polygonToLine === 'function') {
									const boundaryLine = turf.polygonToLine(lakewoodBoundary);
									const split = turf.lineSplit(routeLine, boundaryLine);

									if (split && split.features && split.features.length > 0) {
										split.features.forEach((seg) => {
											const segLen = turf.length(seg, { units: 'miles' });
											if (!segLen) return;

											// Midpoint test decides whether the whole segment is inside.
											const mid = turf.along(seg, segLen / 2, { units: 'miles' });
											const isInside = turf.booleanPointInPolygon(mid, lakewoodBoundary);

											if (isInside) {
												distance += segLen;
												insideSegmentsForMap.push(seg.geometry.coordinates);
											}
										});
									}
								}
							} catch (e) {
								// Fall back below.
							}

							// Fallback: approximate with per-edge midpoint inclusion.
							// This avoids hard failures when lineSplit/polygonToLine aren't available.
							if (insideSegmentsForMap.length === 0) {
								for (let j = 0; j < coordinates.length - 1; j++) {
									const a = coordinates[j];
									const b = coordinates[j + 1];
									const seg = turf.lineString([a, b]);
									const segLen = turf.length(seg, { units: 'miles' });
									if (!segLen) continue;

									const mid = turf.point([(a[0] + b[0]) / 2, (a[1] + b[1]) / 2]);
									const isInside = turf.booleanPointInPolygon(mid, lakewoodBoundary);

									if (isInside) {
										distance += segLen;
										insideSegmentsForMap.push([a, b]);
									}
								}
							}

							// --------
							// Coverage #2: area covered by buffered route inside Lakewood
							// --------
							// Buffer width matches your current implementation (0.01 miles).
							const buffered = turf.buffer(routeLine, 0.01, { units: 'miles' });
							const intersection = turf.intersect(buffered, lakewoodBoundary);
							if (intersection) {
								coverageArea = turf.area(intersection) / 2589988.11; // Convert to square miles
								percentLakewoodTraveled =
									lakewoodAreaSqMiles > 0 ? Math.min(100, (coverageArea / lakewoodAreaSqMiles) * 100) : 0;
							}
						}

						const result = {
							name: file.name,
							// coordinates is kept for debugging/future use; distance/coverage are route-geometry based.
							coordinates: coordinates,
							distance: distance,
							coverageArea: coverageArea,
							percentLakewoodTraveled: percentLakewoodTraveled,
							color: colors[i % colors.length]
						};

						analysisResults.push(result);

						// Add to map (draw only the route portions classified inside Lakewood)
						insideSegmentsForMap.forEach((segCoords) => {
							if (!segCoords || segCoords.length < 2) return;
							L.polyline(
								segCoords.map((c) => [c[1], c[0]]),
								{
									color: result.color,
									weight: 3,
									opacity: 0.7
								}
							).addTo(map);
						});
					}

					displayResults();
				} catch (error) {
					results.innerHTML = `<div class="bg-red-100 border border-red-300 text-red-700 p-4 rounded-lg">Error: ${error.message}</div>`;
				}
			}

			function displayResults() {
				const results = document.getElementById('results');

				// Sort by distance (or coverage area) to find winner
				const sortedResults = [...analysisResults].sort((a, b) => b.distance - a.distance);
				const winner = sortedResults[0];

				let html = '';

				if (winner) {
					html += `<div class="bg-green-100 border border-green-300 text-green-800 p-6 rounded-lg text-center text-lg font-medium mb-6 transition-all duration-300 hover:bg-green-200 enhanced-card">
						🏆 Winner: ${winner.name} with ${winner.distance.toFixed(2)} miles traveled inside Lakewood!
					</div>`;
				}

				analysisResults.forEach((result) => {
					html += `
						<div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg mb-4 border-2 transition-all duration-300 hover:bg-gray-100 enhanced-card" style="border-color: ${result.color};">
							<div class="font-medium text-[#1b1b1b] transition-colors duration-300 hover:text-[#E25A28]" style="color: ${result.color};">${result.name}</div>
							<div class="flex gap-6 text-sm text-[#1b1b1b]/70">
								<div class="text-center">
									<div class="font-bold text-lg text-[#E25A28]">${result.distance.toFixed(2)}</div>
									<div>Miles in Lakewood</div>
								</div>
								<div class="text-center">
									<div class="font-bold text-lg text-[#1C8282]">${result.coverageArea.toFixed(4)}</div>
									<div>Sq Miles Coverage</div>
								</div>
								<div class="text-center">
									<div class="font-bold text-lg text-[#E25A28]">${result.percentLakewoodTraveled.toFixed(1)}%</div>
									<div>% of Lakewood Traveled</div>
								</div>
							</div>
						</div>
					`;
				});

				results.innerHTML = html;
			}

			// Initialize
			document.getElementById('analyzeBtn').addEventListener('click', analyzeFiles);

			// Initialize map when page loads
			document.addEventListener('DOMContentLoaded', initMap);
		</script>
	</body>
</html>

