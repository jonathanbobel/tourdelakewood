---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Route Analyzer"
  description="Upload GPX files from Strava or Garmin and analyze how many miles of your ride fell within Lakewood, Ohio city limits."
>
  <!-- Leaflet + Turf.js injected into <head> via named slot -->
  <link slot="head" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js"></script>

  <style is:global>
    #map { height: 480px; border-radius: 0.65rem; overflow: hidden; }

    .spinner {
      border: 3px solid #2a2a2a;
      border-top: 3px solid var(--yellow);
      border-radius: 50%;
      width: 36px;
      height: 36px;
      animation: tdl-spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }

    @keyframes tdl-spin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .drop-zone.dragover {
      border-color: var(--yellow) !important;
      background: rgba(255, 216, 0, 0.06) !important;
    }
  </style>

  <!-- Page hero -->
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Tour de Lakewood &rsaquo; Route Analyzer</p>
      <h1 class="page-h1">
        Route<br />
        <em>Analyzer</em>
      </h1>
      <p class="page-sub">
        Upload your GPX files and see exactly how many miles of your ride
        fell within Lakewood city limits &mdash; and what percentage of the city you covered.
      </p>
    </div>
  </section>

  <!-- Analyzer tool -->
  <section class="tool-section">
    <div class="tool-container">

      <!-- Boundary status -->
      <div class="status-bar" id="boundaryStatus">
        Loading Lakewood city boundary&hellip;
      </div>

      <!-- Drop zone -->
      <div class="drop-zone" id="fileInputContainer">
        <p class="drop-label">Drop GPX files here or click to upload</p>
        <p class="drop-hint">Select multiple files to compare rides</p>
        <input type="file" id="fileInput" accept=".gpx" multiple class="sr-only" />
      </div>

      <!-- File list -->
      <div id="fileList" class="file-list"></div>

      <!-- Analyze button -->
      <button id="analyzeBtn" disabled class="analyze-btn">
        Analyze Coverage
      </button>

      <!-- Results -->
      <div id="resultsSection" class="results-section hidden">
        <h2 class="results-title">Coverage Analysis</h2>
        <div id="results"></div>
      </div>

      <!-- Map -->
      <div class="map-wrap">
        <h2 class="map-title">Map</h2>
        <div id="map"></div>
      </div>

    </div>
  </section>
</Layout>

