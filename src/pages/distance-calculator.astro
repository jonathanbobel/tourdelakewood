---
import '../styles/tailwind.css';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Tour de Lakewood Distance Calculator - Jonathan Bobel</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@500;600;700&display=swap"
			rel="stylesheet"
		/>

		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />

		<style>
			:root {
				color-scheme: light;
				--bg: #f5f5f5;
				--bg-hero: linear-gradient(180deg, #ffffff 0%, #f4f4f4 55%, #eeeeee 100%);
				--card-bg: #ffffff;
				--card-border: #e5e5e5;
				--accent: #ffd800;
				--accent-soft: rgba(255, 216, 0, 0.18);
				--accent-strong: rgba(0, 0, 0, 0.9);
				--text-main: #1b1b1b;
				--text-muted: #666666;
				--text-soft: #999999;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				min-height: 100%;
				font-family: 'Barlow', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
				background: var(--bg);
				color: var(--text-main);
			}

			body {
				min-height: 100vh;
				background: radial-gradient(circle at top left, #ffffff 0%, #f7f7f7 55%, #eaeaea 100%);
			}

			.coming-soon {
				width: 100%;
				max-width: 720px;
				padding: 2.5rem 1.75rem 3rem;
			}

			.coming-hero {
				background: var(--card-bg);
				border-radius: 1.5rem;
				padding: 2.25rem 2.1rem 2.4rem;
				border: 1px solid #e3e3e3;
				box-shadow: 0 26px 60px rgba(0, 0, 0, 0.12);
				text-align: left;
			}

			.coming-title {
				font-family: 'Barlow Condensed', system-ui, sans-serif;
				font-size: clamp(2.1rem, 3vw, 2.6rem);
				line-height: 1.05;
				margin: 0 0 0.9rem;
				color: #1b1b1b;
			}

			.coming-subtitle {
				margin: 0 0 1.6rem;
				color: #555555;
				font-size: 0.98rem;
				max-width: 32rem;
			}

			.coming-link {
				color: #1b1b1b;
				text-decoration: none;
				border-bottom: 2px solid rgba(17, 17, 17, 0.25);
				transition: border-color 0.2s ease;
				font-weight: 600;
			}

			.coming-link:hover {
				border-bottom-color: #f5d200;
			}

			/* Enhanced focus styles for keyboard navigation */
			*:focus {
				outline: 2px solid #E25A28;
				outline-offset: 2px;
			}

			/* Remove default focus outline for mouse users */
			*:focus:not(:focus-visible) {
				outline: none;
			}

			/* Enhanced focus styles for interactive elements */
			a:focus-visible,
			button:focus-visible,
			input:focus-visible,
			select:focus-visible,
			textarea:focus-visible {
				outline: 3px solid #E25A28;
				outline-offset: 3px;
				border-radius: 4px;
			}

			/* Special focus styles for navigation */
			nav a:focus-visible {
				outline: 3px solid #1C8282;
				outline-offset: 3px;
			}

			/* Focus styles for form elements */
			input:focus-visible,
			textarea:focus-visible {
				outline: 3px solid #E25A28;
				outline-offset: 3px;
				border-color: #E25A28;
			}

			/* Map container sizing */
			#map {
				height: 500px;
			}

			.spinner {
				border: 4px solid #f3f3f3;
				border-top: 4px solid #E25A28;
				border-radius: 50%;
				width: 40px;
				height: 40px;
				animation: spin 1s linear infinite;
				margin: 0 auto 20px;
			}

			@keyframes spin {
				0% {
					transform: rotate(0deg);
				}
				100% {
					transform: rotate(360deg);
				}
			}

			.file-input-container.dragover {
				border-color: #E25A28 !important;
				background-color: #fef7f0 !important;
			}

			/* Enhanced hover effects */
			.enhanced-card {
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.enhanced-card:hover {
				box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
			}

			.enhanced-button {
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.enhanced-button:hover:not(:disabled) {
				box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
			}

			@media (max-width: 640px) {
				.coming-soon {
					padding-inline: 1.25rem;
				}

				.coming-hero {
					padding: 1.9rem 1.6rem 2.1rem;
				}
			}
		</style>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"
		/>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js"></script>
	</head>

		<body class="flex flex-col min-h-screen font-sans">
		<div id="tsparticles"></div>

		<!-- Navbar -->
		<nav class="bg-[#F5F5F5] fixed top-0 left-0 w-full z-50 font-sans">
			<div class="container max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
				<!-- Logo -->
				<a href="/" class="text-3xl font-bold hover:text-[#E25A28] transition-colors duration-300"
					>Tour de Lakewood</a
				>

				<!-- Hamburger / X Toggle Button -->
				<button
					id="menu-btn"
					class="relative z-50 flex flex-col justify-center items-center w-8 h-8 space-y-1 md:hidden group focus:outline-none"
					aria-label="Toggle menu"
				>
					<span
						class="w-8 h-1 bg-[#1b1b1b] transition-all duration-300 ease-in-out origin-center group-[.open]:rotate-45 group-[.open]:translate-y-2"
					></span>
					<span class="w-8 h-1 bg-[#1b1b1b] transition-all duration-300 ease-in-out group-[.open]:opacity-0"></span>
					<span
						class="w-8 h-1 bg-[#1b1b1b] transition-all duration-300 ease-in-out origin-center group-[.open]:-rotate-45 group-[.open]:-translate-y-2"
					></span>
				</button>

				<!-- Navigation Links -->
				<ul id="menu" class="hidden md:flex space-x-6 text-2xl font-bold">
					<li>
						<a
							href="#tour-de-lakewood-calculator"
							class="relative hover:before:scale-x-100 before:absolute before:bottom-[-4px] before:left-0 before:w-full before:h-[4px] before:bg-[#1C8282] before:scale-x-0 before:origin-left before:transition-transform before:duration-300"
							>Calculator</a
						>
					</li>
				</ul>
			</div>

			<!-- Mobile Slide-in Menu -->
			<div
				id="mobile-menu"
				class="fixed top-0 right-0 h-full w-3/4 max-w-sm bg-[#F5F5F5] text-[#1b1b1b] transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-40 flex flex-col space-y-6 p-6"
			>
				<a href="#tour-de-lakewood-calculator" class="text-xl hover:text-[#1C8282]">Calculator</a>
			</div>
		</nav>

		<!-- Backdrop Overlay -->
		<div
			id="menu-backdrop"
			class="fixed inset-0 bg-neutral-800 bg-opacity-40 opacity-0 hidden z-30 md:hidden transition-opacity duration-300 ease-in-out"
		></div>

		<main class="flex-grow pt-24 flex items-center justify-center">
			<section
				id="tour-de-lakewood-calculator"
				class="w-full flex flex-col items-center justify-center coming-soon space-y-8"
			>
				<div class="text-center">
					<h1 class="coming-title mb-4 transition-all duration-300">
						🚴‍♂️ Tour de Lakewood
					</h1>
					<p class="coming-subtitle transition-colors duration-300 hover:text-[#1b1b1b]">
						Compare your Strava routes within Lakewood, OH
					</p>
				</div>

				<div class="w-full coming-hero space-y-6 enhanced-card">
					<div
						id="boundaryStatus"
						class="bg-[#1C8282]/10 border border-[#1C8282]/30 rounded-lg p-4 text-center text-sm text-[#1C8282] transition-all duration-300 hover:bg-[#1C8282]/20"
					>
						Loading Lakewood city boundary...
					</div>

					<div
						id="fileInputContainer"
						class="border-4 border-dashed border-[#E25A28]/40 rounded-xl p-12 text-center transition-all duration-300 cursor-pointer hover:border-[#E25A28] hover:bg-[#E25A28]/5 enhanced-card file-input-container"
					>
						<div class="text-lg text-[#E25A28] font-medium mb-2 transition-colors duration-300 hover:text-[#1C8282]">
							📁 Click to upload GPX files or drag & drop
						</div>
						<div class="text-[#1b1b1b]/60 text-sm transition-colors duration-300 hover:text-[#1b1b1b]">
							Select multiple GPX files to compare coverage
						</div>
						<input type="file" id="fileInput" accept=".gpx" multiple class="hidden" />
					</div>

					<div id="fileList" class="space-y-3"></div>

					<button
						id="analyzeBtn"
						disabled
						class="w-full bg-[#E25A28] hover:bg-[#E25A28]/90 text-white font-medium py-4 px-6 rounded-lg transition-all duration-300 transform disabled:bg-gray-200 disabled:cursor-not-allowed disabled:text-[#1b1b1b]/70 disabled:hover:scale-100 enhanced-button"
					>
						Analyze Coverage
					</button>
				</div>

				<div
					id="resultsSection"
					class="hidden w-full coming-hero enhanced-card"
				>
					<h2 class="text-2xl font-bold text-[#1b1b1b] mb-6 transition-all duration-300 hover:text-[#E25A28]">
						Coverage Analysis Results
					</h2>
					<div id="results"></div>
				</div>

				<div class="w-full coming-hero enhanced-card">
					<h2 class="text-2xl font-bold text-[#1b1b1b] mb-6 transition-all duration-300 hover:text-[#E25A28]">
						Map Visualization
					</h2>
					<div
						id="map"
						class="rounded-lg overflow-hidden border border-gray-200 transition-all duration-300 hover:border-[#E25A28]/50"
					></div>
				</div>
			</section>
		</main>

		<footer class="bg-[#1b1b1b] text-[#F5F5F5] py-3 text-center font-sans">
			<p>&copy; 2025 Jonathan Bobel. All rights reserved.</p>
		</footer>

		<script>
			// @ts-nocheck
			// Simple mobile menu toggle for the Tailwind arbitrary variants.
			(() => {
				const menuBtn = document.getElementById('menu-btn');
				const mobileMenu = document.getElementById('mobile-menu');
				const backdrop = document.getElementById('menu-backdrop');
				if (!menuBtn || !mobileMenu || !backdrop) return;

				const close = () => {
					menuBtn.classList.remove('open');
					mobileMenu.classList.add('translate-x-full');
					mobileMenu.classList.remove('translate-x-0');
					backdrop.classList.add('hidden', 'opacity-0');
					backdrop.classList.remove('opacity-100');
				};

				const open = () => {
					menuBtn.classList.add('open');
					mobileMenu.classList.remove('translate-x-full');
					mobileMenu.classList.add('translate-x-0');
					backdrop.classList.remove('hidden', 'opacity-0');
					backdrop.classList.add('opacity-100');
				};

				menuBtn.addEventListener('click', () => {
					const isOpen = mobileMenu.classList.contains('translate-x-0');
					if (isOpen) close();
					else open();
				});

				backdrop.addEventListener('click', close);
			})();

