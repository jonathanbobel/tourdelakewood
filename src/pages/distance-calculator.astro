          [-81.784189, 41.500048],
          [-81.78521, 41.500048],
          [-81.794234, 41.500048],
          [-81.802425, 41.500048],
          [-81.806419, 41.499584],
          [-81.808583, 41.499332],
          [-81.810963, 41.499172],
          [-81.815384, 41.498806],
          [-81.820562, 41.498066],
          [-81.82703, 41.496913],
          [-81.843982, 41.494593]
        ]
      ]
    },
    properties: { name: 'Lakewood, OH (OpenStreetMap boundary)' }
  };

  // ── Road network (OSM via Overpass API) ─────────────────────────────────────
  const OVERPASS     = 'https://overpass-api.de/api/interpreter';
  const ROAD_CACHE_K = 'tdl_roads_v4';
  const CACHE_TTL    = 7 * 24 * 60 * 60 * 1000;
  const SNAP_KM      = 0.025; // 25 m buffer, same approach as Wandrer

  // Rideable roads only — excludes footways, alleys, paths, service roads
  // which inflate the count when they run parallel/adjacent to the actual route
  const HW_FILTER = 'primary|secondary|tertiary|unclassified|residential|living_street|cycleway';

  let roadNet     = null;
  let roadPromise = null;
  let roadLayer   = null;

  async function fetchRoads() {
    if (roadNet) return roadNet;
    try {
      const c = JSON.parse(localStorage.getItem(ROAD_CACHE_K));
      if (c && Date.now() - c.ts < CACHE_TTL) { roadNet = c.d; return roadNet; }
    } catch (_) {}

    const q = `[out:json][timeout:60];(way["highway"~"^(${HW_FILTER})$"](41.463,-81.844,41.501,-81.769););out geom;`;
    const r  = await fetch(OVERPASS, { method: 'POST', body: q });
    if (!r.ok) throw new Error(`Overpass API error ${r.status}`);
    const js = await r.json();

    let totalMiles = 0;
    const features = [];
    for (const el of js.elements) {
      if (el.type !== 'way' || !el.geometry || el.geometry.length < 2) continue;
      const coords = el.geometry.map(n => [n.lon, n.lat]);
      const feat = {
        type: 'Feature',
        properties: { id: el.id, hw: el.tags?.highway || '', name: el.tags?.name || '' },
        geometry: { type: 'LineString', coordinates: coords }
      };
      if (!turf.booleanIntersects(feat, lakewoodBoundary)) continue;
      totalMiles += turf.length(feat, { units: 'miles' });
      features.push(feat);
    }

    roadNet = { type: 'FeatureCollection', features, totalMiles };
    try { localStorage.setItem(ROAD_CACHE_K, JSON.stringify({ ts: Date.now(), d: roadNet })); } catch (_) {}
    return roadNet;
  }

  function loadRoads() {
    if (!roadPromise) roadPromise = fetchRoads();
    return roadPromise;
  }

  function setRoadStatus(state, count) {
    const el = document.getElementById('roadStatus');
    if (!el) return;
    if (state === 'loading') {
      el.textContent = 'Loading road network…';
      el.className = 'road-status road-status--loading';
    } else if (state === 'ready') {
      el.textContent = `${count.toLocaleString()} road segments loaded`;
      el.className = 'road-status road-status--ready';
    } else {
      el.textContent = 'Road network unavailable';
      el.className = 'road-status road-status--error';
    }
  }

  function drawRoadBase(_net) {
    // nothing — OSM tiles already show the street network
  }

  function highlightRoads(_net, _coveredIds) {
    // nothing — road coverage is shown in the stats panel, not on the map
  }

  async function analyzeRoads(coords) {
    const net     = await loadRoads();
    const buf     = turf.buffer(turf.lineString(coords), SNAP_KM, { units: 'kilometers' });
    const bufEdge = turf.polygonToLine(buf);
    let coveredMiles = 0;
    const coveredIds = new Set();
    for (const road of net.features) {
      if (!turf.booleanIntersects(road, buf)) continue;
      // Split the road at the buffer boundary and only count the portion inside
      let inside = 0;
      try {
        const split = turf.lineSplit(road, bufEdge);
        const segs  = split.features.length > 0 ? split.features : [road];
        for (const seg of segs) {
          const len = turf.length(seg, { units: 'miles' });
          if (!len) continue;
          const mid = turf.along(seg, len / 2, { units: 'miles' });
          if (turf.booleanPointInPolygon(mid, buf)) inside += len;
        }
      } catch (_) {
        inside = turf.length(road, { units: 'miles' });
      }
      if (inside > 0) {
        coveredMiles += inside;
        coveredIds.add(road.properties.id);
      }
    }
    const pct = net.totalMiles > 0 ? Math.min(100, (coveredMiles / net.totalMiles) * 100) : 0;
    return { coveredMiles, totalMiles: net.totalMiles, pct, coveredIds, net };
  }

  // ── Map & state ───────────────────────────────────────────────────────────────
  let map;
  let files = [];
  let analysisResults = [];

  async function initMap() {
    map = L.map('map').setView([41.4856, -81.8017], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    L.geoJSON(lakewoodBoundary, {
      style: { color: '#F2A900', weight: 2, fillColor: '#F2A900', fillOpacity: 0.05 }
    }).addTo(map).bindPopup('Lakewood, OH city boundary');

    setRoadStatus('loading');
    loadRoads()
      .then(net => { drawRoadBase(net); setRoadStatus('ready', net.features.length); })
      .catch(() => setRoadStatus('error'));
  }

  document.getElementById('fileInputContainer').addEventListener('click', () => {
    document.getElementById('fileInput').click();
  });
  document.getElementById('fileInput').addEventListener('change', handleFileSelect);

  document.getElementById('fileInputContainer').addEventListener('dragover', (e) => {
    e.preventDefault();
    e.currentTarget.classList.add('dragover');
  });
  document.getElementById('fileInputContainer').addEventListener('dragleave', (e) => {
    e.currentTarget.classList.remove('dragover');
  });
  document.getElementById('fileInputContainer').addEventListener('drop', (e) => {
    e.preventDefault();
    e.currentTarget.classList.remove('dragover');
    handleFileSelect({ target: { files: e.dataTransfer.files } });
  });

  function handleFileSelect(event) {
    files = [...files, ...Array.from(event.target.files)];
    renderFileList();
    document.getElementById('analyzeBtn').disabled = files.length === 0;
  }

  function renderFileList() {
    const list = document.getElementById('fileList');
    list.innerHTML = '';
    files.forEach((file, i) => {
      const item = document.createElement('div');
      item.className = 'file-item';
      item.innerHTML = `
        <span class="file-name">${file.name}</span>
        <button class="file-remove" onclick="removeFile(${i})">Remove</button>
      `;
      list.appendChild(item);
    });
  }

  function removeFile(index) {
    files.splice(index, 1);
    renderFileList();
    document.getElementById('analyzeBtn').disabled = files.length === 0;
  }

  function parseGPX(gpxText) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(gpxText, 'text/xml');
    const coords = [];
    doc.querySelectorAll('trkpt').forEach(pt => {
      coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
    });
    if (!coords.length) {
      doc.querySelectorAll('wpt').forEach(pt => {
        coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
      });
    }
    return coords;
  }

  async function analyzeFiles() {
    const section   = document.getElementById('resultsSection');
    const resultsEl = document.getElementById('results');
    section.classList.remove('hidden');
    resultsEl.innerHTML = '<div class="analyzing"><div class="spinner"></div><p>Loading road network &amp; analyzing GPX files&hellip;</p></div>';

    analysisResults = [];
    const colors = ['#F2A900', '#E25A28', '#1C8282', '#aaaaaa', '#ff6b6b', '#4ecdc4'];

    try {
      for (let i = 0; i < files.length; i++) {
        const file   = files[i];
        const coords = parseGPX(await file.text());
        if (!coords.length) throw new Error(`No coordinates found in ${file.name}`);

        // Miles of GPX track inside Lakewood boundary
        let milesInLakewood = 0;
        let insideSegs = [];

        if (coords.length > 1) {
          const line = turf.lineString(coords);
          try {
            if (turf.lineSplit && turf.polygonToLine) {
              const split = turf.lineSplit(line, turf.polygonToLine(lakewoodBoundary));
              if (split?.features?.length) {
                split.features.forEach(seg => {
                  const len = turf.length(seg, { units: 'miles' });
                  if (!len) return;
                  const mid = turf.along(seg, len / 2, { units: 'miles' });
                  if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) {
                    milesInLakewood += len;
                    insideSegs.push(seg.geometry.coordinates);
                  }
                });
              }
            }
          } catch (_) {}

          if (!insideSegs.length) {
            for (let j = 0; j < coords.length - 1; j++) {
              const [a, b] = [coords[j], coords[j+1]];
              const seg = turf.lineString([a, b]);
              const len = turf.length(seg, { units: 'miles' });
              if (!len) continue;
              const mid = turf.point([(a[0]+b[0])/2, (a[1]+b[1])/2]);
              if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) {
                milesInLakewood += len;
                insideSegs.push([a, b]);
              }
            }
          }
        }

        // Road coverage via 25 m snap buffer
        const roads = await analyzeRoads(coords);
        const color = colors[i % colors.length];

        analysisResults.push({
          name: file.name,
          milesInLakewood,
          roadMilesCovered: roads.coveredMiles,
          roadMilesTotal:   roads.totalMiles,
          roadPct:          roads.pct,
          color,
          insideSegs,
        });

        highlightRoads(roads.net, roads.coveredIds);

        // Draw the full GPS track as one polyline
        L.polyline(coords.map(c => [c[1], c[0]]), {
          color: '#5F259F', weight: 3.5, opacity: 0.95
        }).addTo(map);
      }

      renderResults();
    } catch (err) {
      resultsEl.innerHTML = `<div class="result-error">Error: ${err.message}</div>`;
    }
  }

  function renderResults() {
    const sorted  = [...analysisResults].sort((a, b) => b.roadPct - a.roadPct);
    const isMulti = analysisResults.length > 1;
    let html = '';

    sorted.forEach((r, i) => {
      const badge = isMulti && i === 0
        ? '<span class="rc-winner-badge">Winner</span>' : '';
      html += `
        <div class="result-card">
          <div class="rc-top">
            <div class="rc-meta">
              <span class="rc-filename">${r.name}</span>
              ${badge}
            </div>
            <div class="rc-hero-stat">
              <span class="rc-big">${r.roadPct.toFixed(1)}%</span>
              <span class="rc-unit">of Lakewood roads</span>
            </div>
          </div>
          <div class="rc-bottom">
            <div class="rc-pair-stat">
              <span class="rc-pair-val">${r.milesInLakewood.toFixed(2)}</span>
              <span class="rc-pair-lbl">miles in Lakewood</span>
            </div>
            <div class="rc-pair-stat">
              <span class="rc-pair-val">${r.roadMilesCovered.toFixed(2)}</span>
              <span class="rc-pair-lbl">road miles covered</span>
            </div>
          </div>
        </div>
      `;
    });

    document.getElementById('results').innerHTML = html;
  }

  document.getElementById('analyzeBtn').addEventListener('click', analyzeFiles);
  document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  /* Page hero */
  .page-hero {
    background: var(--purple);
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero-inner { max-width: var(--container); margin: 0 auto; }

  .eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--yellow);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .page-h1 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--white);
    margin: 0 0 1.25rem;
  }

  .page-h1 em { font-style: normal; color: var(--yellow); }

  .page-sub {
    font-size: 1rem;
    line-height: 1.65;
    color: #ccc;
    max-width: 34rem;
    margin: 0;
  }

  /* Tool section */
  .tool-section {
    background: var(--gray-light);
    padding: 3rem 1.5rem 5rem;
  }

  .tool-container {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Status bar */
  .status-bar {
