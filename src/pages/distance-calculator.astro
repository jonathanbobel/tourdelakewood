      ]
    },
    properties: { name: 'Lakewood, OH (OpenStreetMap boundary)' }
  };

  let map;
  let files = [];
  let analysisResults = [];

  async function initMap() {
    const statusEl = document.getElementById('boundaryStatus');
    if (statusEl) {
      statusEl.textContent = '✅ Lakewood city boundary loaded';
      statusEl.classList.add('status-bar--ok');
    }

    map = L.map('map').setView([41.4856, -81.8017], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    L.geoJSON(lakewoodBoundary, {
      style: { color: '#F2A900', weight: 2, fillColor: '#F2A900', fillOpacity: 0.07 }
    }).addTo(map).bindPopup('Lakewood, OH city boundary');
  }

  document.getElementById('fileInputContainer').addEventListener('click', () => {
    document.getElementById('fileInput').click();
  });
  document.getElementById('fileInput').addEventListener('change', handleFileSelect);

  document.getElementById('fileInputContainer').addEventListener('dragover', (e) => {
    e.preventDefault();
    e.currentTarget.classList.add('dragover');
  });
  document.getElementById('fileInputContainer').addEventListener('dragleave', (e) => {
    e.currentTarget.classList.remove('dragover');
  });
  document.getElementById('fileInputContainer').addEventListener('drop', (e) => {
    e.preventDefault();
    e.currentTarget.classList.remove('dragover');
    handleFileSelect({ target: { files: e.dataTransfer.files } });
  });

  function handleFileSelect(event) {
    files = [...files, ...Array.from(event.target.files)];
    renderFileList();
    document.getElementById('analyzeBtn').disabled = files.length === 0;
  }

  function renderFileList() {
    const list = document.getElementById('fileList');
    list.innerHTML = '';
    files.forEach((file, i) => {
      const item = document.createElement('div');
      item.className = 'file-item';
      item.innerHTML = `
        <span class="file-name">${file.name}</span>
        <button class="file-remove" onclick="removeFile(${i})">Remove</button>
      `;
      list.appendChild(item);
    });
  }

  function removeFile(index) {
    files.splice(index, 1);
    renderFileList();
    document.getElementById('analyzeBtn').disabled = files.length === 0;
  }

  function parseGPX(gpxText) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(gpxText, 'text/xml');
    const coords = [];
    doc.querySelectorAll('trkpt').forEach(pt => {
      coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
    });
    if (!coords.length) {
      doc.querySelectorAll('wpt').forEach(pt => {
        coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
      });
    }
    return coords;
  }

  async function analyzeFiles() {
    const section = document.getElementById('resultsSection');
    const resultsEl = document.getElementById('results');
    section.classList.remove('hidden');
    resultsEl.innerHTML = '<div class="analyzing"><div class="spinner"></div><p>Analyzing GPX files&hellip;</p></div>';

    analysisResults = [];
    const colors = ['#F2A900', '#E25A28', '#1C8282', '#aaaaaa', '#ff6b6b', '#4ecdc4'];
    const lakewoodAreaSqMi = turf.area(lakewoodBoundary) / 2589988.11;

    try {
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        const coords = parseGPX(await file.text());
        if (!coords.length) throw new Error(`No coordinates found in ${file.name}`);

        let distance = 0;
        let coverageArea = 0;
        let pct = 0;
        let insideSegs = [];

        if (coords.length > 1) {
          const line = turf.lineString(coords);
          try {
            if (turf.lineSplit && turf.polygonToLine) {
              const split = turf.lineSplit(line, turf.polygonToLine(lakewoodBoundary));
              if (split?.features?.length) {
                split.features.forEach(seg => {
                  const len = turf.length(seg, { units: 'miles' });
                  if (!len) return;
                  const mid = turf.along(seg, len / 2, { units: 'miles' });
                  if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) {
                    distance += len;
                    insideSegs.push(seg.geometry.coordinates);
                  }
                });
              }
            }
          } catch (_) {}

          if (!insideSegs.length) {
            for (let j = 0; j < coords.length - 1; j++) {
              const [a, b] = [coords[j], coords[j+1]];
              const seg = turf.lineString([a, b]);
              const len = turf.length(seg, { units: 'miles' });
              if (!len) continue;
              const mid = turf.point([(a[0]+b[0])/2, (a[1]+b[1])/2]);
              if (turf.booleanPointInPolygon(mid, lakewoodBoundary)) {
                distance += len;
                insideSegs.push([a, b]);
              }
            }
          }

          const intersect = turf.intersect(turf.buffer(line, 0.01, { units: 'miles' }), lakewoodBoundary);
          if (intersect) {
            coverageArea = turf.area(intersect) / 2589988.11;
            pct = lakewoodAreaSqMi > 0 ? Math.min(100, (coverageArea / lakewoodAreaSqMi) * 100) : 0;
          }
        }

        const color = colors[i % colors.length];
        analysisResults.push({ name: file.name, distance, coverageArea, pct, color });

        insideSegs.forEach(segCoords => {
          if (segCoords?.length >= 2) {
            L.polyline(segCoords.map(c => [c[1], c[0]]), { color, weight: 3, opacity: 0.85 }).addTo(map);
          }
        });
      }

      renderResults();
    } catch (err) {
      resultsEl.innerHTML = `<div class="result-error">Error: ${err.message}</div>`;
    }
  }

  function renderResults() {
    const sorted = [...analysisResults].sort((a, b) => b.distance - a.distance);
    const winner = sorted[0];
    let html = '';

    if (winner) {
      html += `<div class="winner-card">Winner: <strong>${winner.name}</strong> &mdash; ${winner.distance.toFixed(2)} miles in Lakewood</div>`;
    }

    analysisResults.forEach(r => {
      html += `
        <div class="result-row" style="border-left-color:${r.color}">
          <div class="result-name" style="color:${r.color}">${r.name}</div>
          <div class="result-stats">
            <div class="result-stat">
              <div class="stat-val">${r.distance.toFixed(2)}</div>
              <div class="stat-label">Miles in Lakewood</div>
            </div>
            <div class="result-stat">
              <div class="stat-val">${r.coverageArea.toFixed(4)}</div>
              <div class="stat-label">Sq Miles Coverage</div>
            </div>
            <div class="result-stat">
              <div class="stat-val">${r.pct.toFixed(1)}%</div>
              <div class="stat-label">% of Lakewood</div>
            </div>
          </div>
        </div>
      `;
    });

    document.getElementById('results').innerHTML = html;
  }

  document.getElementById('analyzeBtn').addEventListener('click', analyzeFiles);
  document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  /* Page hero */
  .page-hero {
    background: var(--purple);
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero-inner { max-width: var(--container); margin: 0 auto; }

  .eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--yellow);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .page-h1 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--white);
    margin: 0 0 1.25rem;
  }

  .page-h1 em { font-style: normal; color: var(--yellow); }

  .page-sub {
    font-size: 1rem;
    line-height: 1.65;
    color: #ccc;
    max-width: 34rem;
    margin: 0;
  }

  /* Tool section */
  .tool-section {
    background: var(--gray-light);
    padding: 3rem 1.5rem 5rem;
  }

  .tool-container {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Status bar */
  .status-bar {
    background: #1b1b1b;
    border: 1px solid #333;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    color: #aaa;
    text-align: center;
  }

  .status-bar--ok {
    color: var(--yellow);
    border-color: rgba(255, 216, 0, 0.4);
    background: #1b1b1b;
  }

  /* Drop zone */
  .drop-zone {
    background: var(--white);
    border: 2px dashed var(--card-border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .drop-zone:hover {
    border-color: var(--yellow-border);
    background: var(--yellow-bg);
  }

  .drop-icon { font-size: 2rem; margin-bottom: 0.65rem; }

  .drop-label {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
    margin: 0 0 0.3rem;
  }

  .drop-hint {
    font-size: 1rem;
    color: var(--text-soft);
    margin: 0;
  }

  /* File list */
  .file-list { display: flex; flex-direction: column; gap: 0.6rem; }

  .file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    gap: 1rem;
  }

  .file-name {
    font-size: 1rem;
    color: var(--text);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-remove {
    background: none;
    border: 1px solid var(--card-border);
    border-radius: 0.3rem;
    padding: 0.3rem 0.65rem;
    font-size: 1rem;
    color: var(--text-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s, color 0.15s;
  }

  .file-remove:hover { border-color: #c00; color: #c00; }

  /* Analyze button */
  .analyze-btn {
    background: var(--yellow);
    color: var(--black);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 1rem 1.5rem;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.15s;
    width: 100%;
  }

  .analyze-btn:hover:not(:disabled) { background: #F5B400; }

  .analyze-btn:disabled {
    background: var(--card-border);
    color: var(--text-soft);
    cursor: not-allowed;
  }

  /* Results */
  .results-section {
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }

  .results-section.hidden { display: none; }

  .results-title {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 1.25rem;
  }

  .analyzing {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .winner-card {
    background: var(--yellow-bg);
    border: 1px solid var(--yellow-border);
    border-radius: 0.65rem;
    padding: 1rem 1.25rem;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 1rem;
    text-align: center;
  }

  .result-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid var(--card-border);
    border-left-width: 3px;
    border-radius: 0.5rem;
    padding: 0.9rem 1rem;
