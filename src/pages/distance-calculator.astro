---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Route Analyzer"
  description="Upload GPX files from Strava or Garmin and analyze how many miles of your ride fell within Lakewood, Ohio city limits — and what percentage of the road network you covered."
>
  <!-- Leaflet + Turf.js injected into <head> via named slot -->
  <link slot="head" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js"></script>

  <style is:global>
    #map { height: 480px; border-radius: 0 0 0.65rem 0.65rem; overflow: hidden; }

    .spinner {
      border: 3px solid #2a2a2a;
      border-top: 3px solid var(--yellow);
      border-radius: 50%;
      width: 36px;
      height: 36px;
      animation: tdl-spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }

    @keyframes tdl-spin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .drop-zone.dragover {
      border-color: var(--yellow-border) !important;
      background: var(--yellow-bg) !important;
    }
  </style>

  <!-- Page hero -->
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Tour de Lakewood &rsaquo; Route Analyzer</p>
      <h1 class="page-h1">
        Route<br />
        <em>Analyzer</em>
      </h1>
      <p class="page-sub">
        Upload your GPX files to see how many miles of your ride fell within Lakewood city limits
        &mdash; and what percentage of the road network you covered.
      </p>
    </div>
  </section>

  <!-- Analyzer tool -->
  <section class="tool-section">
    <div class="tool-container">

      <p class="section-tag">Route Analysis</p>

      <div class="tool-grid">

        <!-- Left: Upload controls -->
        <div class="upload-col">
          <div class="upload-card">

            <!-- Drop zone -->
            <div class="drop-zone" id="fileInputContainer">
              <div class="drop-icon-wrap">
                <svg class="drop-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
              </div>
              <p class="drop-label">Drop GPX files here</p>
              <p class="drop-hint">or click to upload &middot; multiple files supported</p>
              <input type="file" id="fileInput" accept=".gpx" multiple class="sr-only" />
            </div>

            <!-- File list -->
            <div id="fileList" class="file-list"></div>

            <!-- Analyze button -->
            <div class="btn-wrap">
              <button id="analyzeBtn" disabled class="analyze-btn">
                Analyze Coverage
              </button>
            </div>

          </div>
        </div>

        <!-- Right: Map -->
        <div class="map-col">
          <div class="map-card">
            <div class="map-card-header">
              <span class="map-card-title">Lakewood, OH</span>
              <div id="roadStatus" class="road-status road-status--loading">Loading road network…</div>
            </div>
            <div id="map"></div>
          </div>
        </div>

      </div>

      <!-- Results — full-width, shown after analysis -->
      <div id="resultsSection" class="results-section hidden">
        <p class="section-tag results-tag">Analysis Results</p>
        <div id="results"></div>
      </div>

    </div>
  </section>
</Layout>

