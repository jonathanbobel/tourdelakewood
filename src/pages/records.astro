        [-81.7785283,41.4700563],[-81.7780534,41.4702501],[-81.7774937,41.4704882],
        [-81.7747545,41.4715878],[-81.7728831,41.4723466],[-81.770864,41.4732132],
        [-81.7706079,41.473329],[-81.7698487,41.4736312],[-81.7688028,41.4739999],
        [-81.7688036,41.4746848],[-81.7688044,41.4754362],[-81.768804,41.4754918],
        [-81.7687933,41.4769251],[-81.7687855,41.4777346],[-81.7687739,41.4789449],
        [-81.768772,41.4794602],[-81.7687744,41.4796439],[-81.7687641,41.4798414],
        [-81.7687604,41.4811905],[-81.76876,41.4816548],[-81.7687536,41.4822667],
        [-81.7687488,41.4827011],[-81.7687481,41.4827647],[-81.7687375,41.4829423],
        [-81.7687471,41.483665],[-81.7687444,41.4842515],[-81.76874,41.4852213],
        [-81.7687404,41.4854621],[-81.7687422,41.4854739],[-81.7687444,41.4857179],
        [-81.7687416,41.4862449],[-81.768742,41.4866069],[-81.7687424,41.4869418],
        [-81.7687431,41.487528],[-81.7687235,41.4880629],[-81.7687173,41.4882763],
        [-81.7687097,41.488513],[-81.7686995,41.488854],[-81.7686981,41.4889872],
        [-81.7686736,41.4898924],[-81.7686715,41.4899705],[-81.7686713,41.4899735],
        [-81.7686133,41.4909595],[-81.7685853,41.4913856],[-81.7685818,41.4914395],
        [-81.7685767,41.4915172],[-81.768576,41.491636],[-81.768912,41.491664],
        [-81.769032,41.497326],[-81.770245,41.49755],[-81.777786,41.498773],
        [-81.782212,41.499655],[-81.784189,41.500048],[-81.78521,41.500048],
        [-81.794234,41.500048],[-81.802425,41.500048],[-81.806419,41.499584],
        [-81.808583,41.499332],[-81.810963,41.499172],[-81.815384,41.498806],
        [-81.820562,41.498066],[-81.82703,41.496913],[-81.843982,41.494593]
      ]]
    },
    properties: { name: 'Lakewood, OH' }
  };

  // Road network (shares localStorage cache with Route Analyzer page)
  const OVERPASS     = 'https://overpass-api.de/api/interpreter';
  const ROAD_CACHE_K = 'tdl_roads_v4';
  const CACHE_TTL    = 7 * 24 * 60 * 60 * 1000;
  const HW_FILTER    = 'primary|secondary|tertiary|unclassified|residential|living_street|cycleway';

  async function fetchRoads() {
    try {
      const c = JSON.parse(localStorage.getItem(ROAD_CACHE_K));
      if (c && Date.now() - c.ts < CACHE_TTL) return c.d;
    } catch (_) {}

    const q = `[out:json][timeout:60];(way["highway"~"^(${HW_FILTER})$"](41.463,-81.844,41.501,-81.769););out geom;`;
    const r  = await fetch(OVERPASS, { method: 'POST', body: q });
    if (!r.ok) throw new Error(`Overpass ${r.status}`);
    const js = await r.json();

    let totalMiles = 0;
    const features = [];
    for (const el of js.elements) {
      if (el.type !== 'way' || !el.geometry || el.geometry.length < 2) continue;
      const coords = el.geometry.map(n => [n.lon, n.lat]);
      const feat = { type: 'Feature', properties: { id: el.id }, geometry: { type: 'LineString', coordinates: coords } };
      if (!turf.booleanIntersects(feat, LAKEWOOD)) continue;
      totalMiles += turf.length(feat, { units: 'miles' });
      features.push(feat);
    }

    const net = { type: 'FeatureCollection', features, totalMiles };
    try { localStorage.setItem(ROAD_CACHE_K, JSON.stringify({ ts: Date.now(), d: net })); } catch (_) {}
    return net;
  }

  function parseGPX(xml) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(xml, 'text/xml');
    const coords = [];
    doc.querySelectorAll('trkpt').forEach(pt => {
      coords.push([parseFloat(pt.getAttribute('lon')), parseFloat(pt.getAttribute('lat'))]);
    });
    return coords;
  }

  function animateCount(el, from, to, duration, format) {
    const start = performance.now();
    function step(now) {
      const p = Math.min(1, (now - start) / duration);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = format(from + (to - from) * ease);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function formatWithComma(v, decimals) {
    return v.toFixed(decimals).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  const COVERAGE_CACHE_K = 'tdl_record_coverage_v3';

  async function initCoverageMap() {
    const map = L.map('coverage-map', { zoomControl: true, scrollWheelZoom: false })
      .setView([41.4856, -81.8017], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors', maxZoom: 18
    }).addTo(map);
    L.geoJSON(LAKEWOOD, {
      style: { color: '#F2A900', weight: 2.5, fillColor: '#F2A900', fillOpacity: 0.05 }
    }).addTo(map);

    // Always fetch the GPX (needed for the map) and road network in parallel
    let net, coords;
    try {
      [net, coords] = await Promise.all([
        fetchRoads(),
        fetch('/Tour_de_Lakewood.gpx').then(r => r.text()).then(parseGPX)
      ]);
    } catch (e) {
      document.getElementById('coverage-loading').style.display = 'none';
      document.getElementById('coverage-stat').style.display = 'flex';
      document.getElementById('coverage-pct').textContent = '—';
      return;
    }

    // Draw the record GPX track — OSM tiles show the full street network
    L.polyline(coords.map(c => [c[1], c[0]]), {
      color: '#5F259F', weight: 3, opacity: 0.85
    }).addTo(map);

    // Check if the expensive coverage analysis is cached
    let pct;
    try {
      const c = JSON.parse(localStorage.getItem(COVERAGE_CACHE_K));
      if (c && Date.now() - c.ts < CACHE_TTL) { pct = c.pct; }
    } catch (_) {}

    if (pct == null) {
      // Run the coverage analysis (slow — cached after first run)
      const buf     = turf.buffer(turf.lineString(coords), 0.025, { units: 'kilometers' });
      const bufEdge = turf.polygonToLine(buf);
      let coveredMiles = 0;
      for (const road of net.features) {
        if (!turf.booleanIntersects(road, buf)) continue;
        let inside = 0;
        try {
          const split = turf.lineSplit(road, bufEdge);
          const segs  = split.features.length > 0 ? split.features : [road];
          for (const seg of segs) {
            const len = turf.length(seg, { units: 'miles' });
            if (!len) continue;
            const mid = turf.along(seg, len / 2, { units: 'miles' });
            if (turf.booleanPointInPolygon(mid, buf)) inside += len;
          }
        } catch (_) {
          inside = turf.length(road, { units: 'miles' });
        }
        coveredMiles += inside;
      }
      pct = net.totalMiles > 0 ? Math.min(100, (coveredMiles / net.totalMiles) * 100) : 0;
      try {
        localStorage.setItem(COVERAGE_CACHE_K, JSON.stringify({ ts: Date.now(), pct }));
      } catch (_) {}
    }

    document.getElementById('coverage-loading').style.display = 'none';
    document.getElementById('coverage-stat').style.display = 'flex';
    animateCount(document.getElementById('coverage-pct'), 0, pct, 1800, v => v.toFixed(1) + '%');
  }

  function setupCountUps() {
    const cards = document.querySelectorAll('[data-countup]');
    cards.forEach(card => {
      const target = parseFloat(card.dataset.target);
      const decimals = parseInt(card.dataset.decimals, 10);
      const id = card.dataset.id;
      const el = document.getElementById(id);
      if (!el) return;

      let triggered = false;
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting && !triggered) {
          triggered = true;
          obs.disconnect();
          animateCount(el, 0, target, 2200, v => formatWithComma(v, decimals));
        }
      }, { threshold: 0.4 });
      obs.observe(card);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCoverageMap();
    setupCountUps();
  });
</script>

<style>
  .page-hero {
    background: var(--purple);
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero-inner { max-width: var(--container); margin: 0 auto; }

  .eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--yellow);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .page-h1 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--white);
    margin: 0 0 1.25rem;
  }

  .page-h1 em { font-style: normal; color: var(--yellow); }

  .page-sub {
    font-size: 1rem;
    line-height: 1.65;
    color: #ccc;
    max-width: 34rem;
    margin: 0;
  }

  /* Records section */
  .records-section {
    background: var(--gray-light);
    padding: 3rem 1.5rem 5rem;
  }

  .records-container {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-tag {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-soft);
    font-weight: 700;
    margin: 0 0 0.25rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--yellow);
  }

  /* Record cards */
  .record-card {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .record-card--dark {
    background: #1b1b1b;
    border: 1px solid #2a2a2a;
  }

  .record-card--light {
    background: var(--white);
    border: 1px solid var(--card-border);
    padding: 2rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Coverage card top bar */
  .rc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.75rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .rc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .rc-category {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: #aaa;
  }

  .record-card--light .rc-category {
    color: var(--text-soft);
  }

  .rc-holder-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .rc-crown {
    font-size: 1.1rem;
    color: var(--yellow);
    line-height: 1;
  }

  .rc-holder {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--white);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .record-card--light .rc-holder {
    color: var(--text);
  }

  /* Stat block */
  .rc-stat-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .rc-stat-block--center {
    align-items: flex-start;
    margin-top: auto;
  }

  .rc-big {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1;
    color: var(--yellow);
    letter-spacing: -0.02em;
    display: block;
  }

  .rc-big--yellow { color: var(--yellow); }

  .rc-unit {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #999;
    font-weight: 600;
  }

  .record-card--light .rc-unit {
    color: var(--text-soft);
  }

  .rc-note {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
    border-top: 1px solid var(--card-border);
    padding-top: 0.75rem;
    margin-top: auto;
  }

  /* Loading state */
  .rc-loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: #666;
    font-size: 0.9rem;
  }

  .rc-spinner {
    width: 28px;
    height: 28px;
    border: 3px solid #2a2a2a;
    border-top-color: var(--yellow);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .rc-stat-inner {
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  /* Map wrapper inside coverage card */
  .map-wrap {
    border-top: 1px solid #2a2a2a;
  }

  /* Pair of side-by-side cards */
  .record-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .records-section { padding: 2rem 1.25rem 4rem; }
    .rc-top { padding: 1.25rem; }
    .record-pair { grid-template-columns: 1fr; }
    .rc-stat-block { align-items: flex-start; }
    .rc-stat-inner { align-items: flex-start; }
  }
</style>
