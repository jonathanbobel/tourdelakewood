        [-81.8221175,41.4681358],[-81.8208104,41.468124],[-81.8195138,41.4681122],
        [-81.8189816,41.4681122],[-81.8184713,41.4681472],[-81.818063,41.468145],
        [-81.8177062,41.4680863],[-81.8173772,41.4680016],[-81.8167526,41.4678425],
        [-81.8163369,41.4677517],[-81.815674,41.467529],[-81.8152641,41.4680553],
        [-81.8141418,41.4680332],[-81.8118693,41.4680132],[-81.8107805,41.4680092],
        [-81.8106005,41.468006],[-81.810396,41.468003],[-81.8104472,41.4690603],
        [-81.8106017,41.4694904],[-81.8107572,41.4695527],[-81.8107492,41.4697678],
        [-81.810357,41.469941],[-81.8088086,41.4699566],[-81.806064,41.470083],
        [-81.804739,41.470148],[-81.803435,41.470042],[-81.80053,41.470008],
        [-81.799999,41.469922],[-81.7974059,41.469929],[-81.7969663,41.4699415],
        [-81.7968161,41.4699457],[-81.7965141,41.4699543],[-81.7960775,41.4699679],
        [-81.7950413,41.4700003],[-81.7939402,41.4700198],[-81.7934539,41.470032],
        [-81.7929386,41.4700449],[-81.792055,41.4700729],[-81.7915473,41.4700879],
        [-81.79092,41.4701266],[-81.7903942,41.4701882],[-81.7898057,41.4702978],
        [-81.789748,41.4703101],[-81.7896994,41.4703206],[-81.7896669,41.470326],
        [-81.7893396,41.4703885],[-81.7890078,41.4704519],[-81.7885292,41.470451],
