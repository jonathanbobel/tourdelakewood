---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Records"
  description="All-time Tour de Lakewood records for map coverage, distance, and elevation — currently held by Nat Simonetti."
>
  <link slot="head" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script is:inline slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js"></script>

  <style is:global>
    #coverage-map { height: 480px; border-radius: 0 0 0.65rem 0.65rem; overflow: hidden; }
  </style>

  <!-- Hero -->
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Tour de Lakewood &rsaquo; Records</p>
      <h1 class="page-h1">
        All&#8209;Time<br />
        <em>Records</em>
      </h1>
      <p class="page-sub">
        The marks to beat. Three categories, one record holder &mdash; for now.
      </p>
    </div>
  </section>

  <!-- Records -->
  <section class="records-section">
    <div class="records-container">

      <p class="section-tag">All-Time Records</p>

      <!-- Coverage record — full width -->
      <div class="record-card record-card--dark">
        <div class="rc-top">
          <div class="rc-meta">
            <span class="rc-category">Map Coverage</span>
            <span class="rc-holder-row">
              <span class="rc-crown" aria-hidden="true">&#9812;</span>
              <span class="rc-holder">Nat Simonetti</span>
            </span>
          </div>
          <div class="rc-stat-block">
            <div class="rc-loading-state" id="coverage-loading">
              <div class="rc-spinner"></div>
              <span>Computing&hellip;</span>
            </div>
            <div class="rc-stat-inner" id="coverage-stat" style="display:none">
              <span class="rc-big" id="coverage-pct">—</span>
              <span class="rc-unit">of roads covered</span>
            </div>
          </div>
        </div>
        <div class="map-wrap">
          <div id="coverage-map"></div>
        </div>
      </div>

      <!-- Distance + Elevation side by side -->
      <div class="record-pair">

        <div class="record-card record-card--light" data-countup data-target="117.96" data-decimals="2" data-id="dist-val">
          <span class="rc-category">Total Distance</span>
          <div class="rc-holder-row">
            <span class="rc-crown" aria-hidden="true">&#9812;</span>
            <span class="rc-holder">Nat Simonetti</span>
          </div>
          <div class="rc-stat-block rc-stat-block--center">
            <span class="rc-big rc-big--yellow" id="dist-val">0.00</span>
            <span class="rc-unit">miles</span>
          </div>
          <p class="rc-note">Total distance ridden within Lakewood city limits</p>
        </div>

        <div class="record-card record-card--light" data-countup data-target="4171" data-decimals="0" data-id="ele-val">
          <span class="rc-category">Elevation Gain</span>
          <div class="rc-holder-row">
            <span class="rc-crown" aria-hidden="true">&#9812;</span>
            <span class="rc-holder">Nat Simonetti</span>
          </div>
          <div class="rc-stat-block rc-stat-block--center">
            <span class="rc-big rc-big--yellow" id="ele-val">0</span>
            <span class="rc-unit">feet</span>
          </div>
          <p class="rc-note">Total elevation gain across the full ride</p>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // @ts-nocheck
  const LAKEWOOD = {
    type: 'Feature',
    geometry: {
