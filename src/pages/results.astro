---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Results"
  description="Tour de Lakewood 2026 results — posted after the event on July 11th, 2026."
>
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Tour de Lakewood 2026</p>
      <h1 class="hero-h1">
        Results<br />
        <em>Board</em>
      </h1>
    </div>
  </section>

  <section id="tbd-section" class="tbd-section">
    <div class="container">
      <div class="tbd-card">
        <div class="tbd-badge">
          <span class="dot"></span>
          <span>Event coming up &mdash; no results yet</span>
        </div>

        <h2 class="tbd-h2">Check back on July 12th.</h2>
        <p class="tbd-body">
          Tour de Lakewood takes place on July 11th, 2026. Results will be posted here
          after the event: three leaderboards &mdash; most total distance, most map coverage,
          and most elevation gain.
        </p>

        <p class="tbd-eyebrow">Event starts in</p>
        <div class="countdown" aria-label="Countdown to July 11, 2026 at 8:00 AM">
          <div class="cd-block">
            <span class="cd-val" id="r-days">00</span>
            <span class="cd-unit">Days</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-hours">00</span>
            <span class="cd-unit">Hrs</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-mins">00</span>
            <span class="cd-unit">Min</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-block">
            <span class="cd-val" id="r-secs">00</span>
            <span class="cd-unit">Sec</span>
          </div>
        </div>

        <div class="tbd-meta">
          <div class="tbd-meta-row">Saturday, July 11th, 2026</div>
          <div class="tbd-meta-row">8:00 AM &ndash; 8:00 PM Eastern</div>
          <div class="tbd-meta-row">Lakewood, Ohio</div>
        </div>

        <div class="tbd-actions">
          <a href="/about" class="btn-yellow">Learn about the ride</a>
          <a href="/distance-calculator" class="btn-ghost">Route Analyzer</a>
        </div>
      </div>
    </div>
  </section>
  <!-- Results (shown after feature flag unlocks) -->
  <section id="results-section" class="results-live-section">
    <div class="container">

      <p class="section-tag">2026 Final Results</p>

      <div class="lb-grid">

        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Distance</h2>
            <p class="lb-sub">Total miles within Lakewood</p>
          </div>
          <div id="lb-distance" class="lb-list"></div>
        </div>

        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Coverage</h2>
            <p class="lb-sub">% of Lakewood roads ridden</p>
          </div>
          <div id="lb-coverage" class="lb-list"></div>
        </div>

        <div class="lb-card">
          <div class="lb-header">
            <h2 class="lb-cat">Most Elevation</h2>
            <p class="lb-sub">Total elevation gain</p>
          </div>
          <div id="lb-elevation" class="lb-list"></div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // ── Results data — fill these in after the event ──────────────────────────
  // Each array is ordered 1st → last place.
  const RESULTS = {
    distance: [
      { name: 'Rider Name', value: '—', unit: 'mi' },
      { name: 'Rider Name', value: '—', unit: 'mi' },
      { name: 'Rider Name', value: '—', unit: 'mi' },
    ],
    coverage: [
      { name: 'Rider Name', value: '—', unit: '%' },
      { name: 'Rider Name', value: '—', unit: '%' },
      { name: 'Rider Name', value: '—', unit: '%' },
    ],
    elevation: [
      { name: 'Rider Name', value: '—', unit: 'ft' },
      { name: 'Rider Name', value: '—', unit: 'ft' },
      { name: 'Rider Name', value: '—', unit: 'ft' },
    ],
  };

  // ── Feature flag ──────────────────────────────────────────────────────────
  // Results go live at 8 pm ET on July 11, 2026.
  // To preview locally: add ?preview to the URL (e.g. /results?preview)
  const LAUNCH_MS = new Date('2026-07-11T20:00:00-04:00').getTime();
  const preview   = new URLSearchParams(location.search).has('preview');
  const live      = preview || Date.now() >= LAUNCH_MS;

  const tbdEl     = document.getElementById('tbd-section');
  const resultsEl = document.getElementById('results-section');
  if (tbdEl)     tbdEl.style.display     = live ? 'none' : '';
  if (resultsEl) resultsEl.style.display = live ? ''     : 'none';

  // ── Render leaderboards ───────────────────────────────────────────────────
  const RANK_CLASS = ['lb-rank--gold', 'lb-rank--silver', 'lb-rank--bronze'];

  function renderLeaderboard(id, entries) {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = entries.map((e, i) => {
      const rowMod = i === 0 ? ' lb-row--winner' : i < 3 ? ' lb-row--podium' : '';
      return `
        <div class="lb-row${rowMod}">
          <span class="lb-rank ${RANK_CLASS[i] || ''}">${i + 1}</span>
          <span class="lb-name">${e.name}</span>
          <span class="lb-val">${e.value}<span class="lb-unit"> ${e.unit}</span></span>
        </div>
      `;
    }).join('');
  }

  if (live) {
    renderLeaderboard('lb-distance', RESULTS.distance);
    renderLeaderboard('lb-coverage', RESULTS.coverage);
    renderLeaderboard('lb-elevation', RESULTS.elevation);
  }

  // ── Countdown (only runs when TBD section is showing) ────────────────────
  if (!live) {
    const TARGET = new Date('2026-07-11T08:00:00-04:00').getTime();
    const pad = (n) => String(n).padStart(2, '0');
    const tick = () => {
      const diff = Math.max(0, TARGET - Date.now());
      const s = Math.floor(diff / 1000);
      const d  = document.getElementById('r-days');
      const h  = document.getElementById('r-hours');
      const m  = document.getElementById('r-mins');
      const sc = document.getElementById('r-secs');
      if (d)  d.textContent  = String(Math.floor(s / 86400));
      if (h)  h.textContent  = pad(Math.floor((s % 86400) / 3600));
      if (m)  m.textContent  = pad(Math.floor((s % 3600) / 60));
      if (sc) sc.textContent = pad(s % 60);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

<style>
  .container { max-width: var(--container); margin: 0 auto; }

  /* Hero */
  .hero {
    background: var(--purple);
    padding: 4.5rem 1.5rem 4rem;
  }

  .hero-inner { max-width: var(--container); margin: 0 auto; }

  .eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--yellow);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .hero-h1 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--white);
    margin: 0;
  }

  .hero-h1 em { font-style: normal; color: var(--yellow); }

  /* TBD section */
  .tbd-section {
    background: var(--gray-light);
    padding: 5rem 1.5rem;
  }

  .tbd-card {
    max-width: 560px;
    margin: 0 auto;
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.07);
    text-align: center;
  }

  .tbd-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: var(--yellow-bg);
    border: 1px solid var(--yellow-border);
    color: #5a3800;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #F2A900;
    box-shadow: 0 0 0 3px rgba(242,169,0,0.25);
    flex-shrink: 0;
  }

  .tbd-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .tbd-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2rem;
  }

  .tbd-eyebrow {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-soft);
    font-style: italic;
    margin: 0 0 0.85rem;
  }

  /* Countdown */
  .countdown {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 1.75rem;
  }

  .cd-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .cd-val {
    display: block;
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1;
    color: var(--text);
    background: var(--yellow-bg);
    border: 1px solid var(--yellow-border);
    border-radius: 0.5rem;
    padding: 0.3rem 0.5rem;
    min-width: 66px;
    text-align: center;
  }

  .cd-unit {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .cd-sep {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--card-border);
    line-height: 1;
    flex-shrink: 0;
    padding-top: 0.05em;
  }

  /* Meta rows */
  .tbd-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    text-align: left;
    background: var(--gray-light);
    border-radius: 0.65rem;
    padding: 1rem 1.25rem;
  }

  .tbd-meta-row {
    font-size: 1rem;
    color: var(--text-muted);
  }

  /* Buttons */
  .tbd-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  .btn-yellow {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 0.35rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-yellow:hover { background: #F5B400; }

  .btn-ghost {
    display: inline-block;
    background: transparent;
    color: var(--text);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    border-radius: 0.35rem;
    border: 2px solid var(--card-border);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text); }

  @media (max-width: 600px) {
    .tbd-section { padding: 3rem 1.25rem; }
    .tbd-card { padding: 1.75rem 1.25rem; }
    .cd-val { font-size: 2.1rem; min-width: 52px; }
  }

  /* ── Live results section ───────────────────────────────────────────────── */
  .results-live-section {
    background: var(--gray-light);
    padding: 3rem 1.5rem 5rem;
  }

  .section-tag {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-soft);
    font-weight: 700;
    margin: 0 0 1.5rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--yellow);
  }

  .lb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: start;
  }

  .lb-card {
    background: var(--white);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .lb-header {
    padding: 1.25rem 1.5rem 1rem;
    border-bottom: 1px solid var(--card-border);
  }

  .lb-cat {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 0.2rem;
    letter-spacing: 0.04em;
  }

  .lb-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .lb-list {
    display: flex;
    flex-direction: column;
  }

  /* Winner row — purple card, yellow value */
  .lb-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--card-border);
  }
  .lb-row:last-child { border-bottom: none; }

  .lb-row--winner {
    background: var(--purple);
    padding: 1.1rem 1.25rem;
  }
  .lb-row--winner .lb-name { color: #fff; font-size: 1.05rem; }
  .lb-row--winner .lb-val  { color: var(--yellow); font-size: 1.5rem; }
  .lb-row--winner .lb-unit { color: rgba(255,255,255,0.5); }

  /* 2nd / 3rd place — subtle yellow tint */
  .lb-row--podium { background: var(--yellow-bg); }

  .lb-rank {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--card-border);
    color: var(--text-muted);
  }
  .lb-rank--gold   { background: #F2A900; color: #1b1b1b; }
  .lb-rank--silver { background: #b8b8b8; color: #1b1b1b; }
  .lb-rank--bronze { background: #b87333; color: #fff; }

  .lb-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
    flex: 1;
  }

  .lb-val {
    font-family: 'Barlow Condensed', 'Arial Narrow', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    white-space: nowrap;
  }

  .lb-unit {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  @media (max-width: 860px) {
    .lb-grid { grid-template-columns: 1fr; }
    .results-live-section { padding: 2rem 1.25rem 4rem; }
  }
</style>
